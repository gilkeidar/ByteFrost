0x2d, 0x11,	// 0x08f8: OUT #0x11, I
0x0d, 0x3a,	// 0x08fa: OUT ':'
0x0d, 0x20,	// 0x08fc: OUT ' '

0x0d, 0x4a,	// 0x08fe: OUT 'J'
0x0d, 0x53,	// 0x0900: OUT 'S'
0x0d, 0x52,	// 0x0902: OUT 'R'
0x0d, 0x20,	// 0x0904: OUT ' '
0x0d, 0x52,	// 0x0906: OUT 'R'
0x0d, 0x54,	// 0x0908: OUT 'T'
0x0d, 0x53,	// 0x090a: OUT 'S'
0x0d, 0x10,	// 0x090c: OUT '\n'

.define 2 stack_head2		0xAAAA

.define 2 recursion_level 	0x6000

0xbb, 0xaa,	// 0x090e: LDA %SP, H, stack_head2[1]
0x9b, 0xaa,	// 0x0910: LDA %SP, L, stack_head2[0]

0x7b, 0x60,	// 0x0912: LDA %DP, H, recursion_level[1]
0x5b, 0x00,	// 0x0914: LDA %DP, L, recursion_level[0]

// Recursion level
0xc3, 0x06,	// 0x0916: LDR R3, #6
0xd7, 0x00,	// 0x0918: SDW R3, %DP, #0

0x0d, 0x50,	// 0x091a: OUT 'P'
0x0d, 0x55,	// 0x091c: OUT 'U'
0x0d, 0x53,	// 0x091e: OUT 'S'
0x0d, 0x48,	// 0x0920: OUT 'H'
0x0d, 0x20,	// 0x0922: OUT ' '
0x5b, 0x3c,	// 0x0924: CALL :recursion
0x7b, 0x09,	// 0x0926: (CALL continued)
0x10, 0x00,	// 0x0928: (CALL continued)
0x0d, 0x10,	// 0x092a: OUT '\n'
0x0d, 0x42,	// 0x092c: OUT 'B'
0x0d, 0x61,	// 0x092e: OUT 'a'
0x0d, 0x63,	// 0x0930: OUT 'c'
0x0d, 0x6b,	// 0x0932: OUT 'k'
0x0d, 0x21,	// 0x0934: OUT '!'
0x0d, 0x10,	// 0x0936: OUT '\n'
0x3b, 0x09,	// 0x0938: JMP :PASS
0x05, 0x80,	// 0x093a: (JMP continued)

:recursion
0x7b, 0x60,	// 0x093c: LDA %DP, H, recursion_level[1]
0x5b, 0x00,	// 0x093e: LDA %DP, L, recursion_level[0]
0xd5, 0x00,	// 0x0940: LDW R3, %DP, #0

0x28, 0x30,	// 0x0942: OUT R3, I
0x0d, 0x20,	// 0x0944: OUT ' '

0x0e, 0x30,	// 0x0946: PUSH R3

0xc6, 0x17,	// 0x0948: DEC R3
0x3b, 0x09,	// 0x094a: BNE :keep_going
0xe5, 0x68,	// 0x094c: (BNE continued)
// Stop condition met
0x83, 0x01,	// 0x094e: LDR R2 , #1
0xcf, 0x00,	// 0x0950: POP R3
0x0d, 0x10,	// 0x0952: OUT '\n'
0x0d, 0x50,	// 0x0954: OUT 'P'
0x0d, 0x4f,	// 0x0956: OUT 'O'
0x0d, 0x50,	// 0x0958: OUT 'P'
0x0d, 0x20,	// 0x095a: OUT ' '
0x28, 0x30,	// 0x095c: OUT R3, I
0x0d, 0x20,	// 0x095e: OUT ' '
0x12, 0xe7,	// 0x0960: TST R2, R3
0x3b, 0x09,	// 0x0962: BNE :FAIL
0xe5, 0xa0,	// 0x0964: (BNE continued)
0x11, 0x00,	// 0x0966: RTS   // Rolling out of deepest recursion

:keep_going
0xd7, 0x00,	// 0x0968: SDW R3, %DP, #0
0x5b, 0x3c,	// 0x096a: CALL :recursion
0x7b, 0x09,	// 0x096c: (CALL continued)
0x10, 0x00,	// 0x096e: (CALL continued)

// Retrun
0xcf, 0x00,	// 0x0970: POP R3

0x28, 0x30,	// 0x0972: OUT R3, I
0x0d, 0x20,	// 0x0974: OUT ' '
0x86, 0x16,	// 0x0976: INC R2
0x12, 0xe7,	// 0x0978: TST R2, R3
0x3b, 0x09,	// 0x097a: BNE :FAIL
0xe5, 0xa0,	// 0x097c: (BNE continued)
0x11, 0x00,	// 0x097e: RTS  // Rolling out of intemediate recursion step

////////////////////////////////////////////

:PASS
// BIST is not using SP as a Stack Pointer, so it needs restore it at the end
0x7b, 0xdf,	// 0x0980: LDA %DP, H, stack_pointer[1]
0x5b, 0x00,	// 0x0982: LDA %DP, L, stack_pointer[0]
0xd5, 0x01,	// 0x0984: LDW R3, %DP, #1
0x95, 0x00,	// 0x0986: LDW R2, %DP, #0
0xbc, 0x30,	// 0x0988: MGA %SP, H, R3
0x9c, 0x20,	// 0x098a: MGA %SP, L, R2

0x0d, 0x10,	// 0x098c: OUT '\n'
0x0d, 0x50,	// 0x098e: OUT 'P'
0x0d, 0x41,	// 0x0990: OUT 'A'
0x0d, 0x53,	// 0x0992: OUT 'S'
0x0d, 0x53,	// 0x0994: OUT 'S'
0x0d, 0x20,	// 0x0996: OUT ' '
0x5b, 0xb4,	// 0x0998: CALL :Test_duration
0x7b, 0x09,	// 0x099a: (CALL continued)
0x10, 0x00,	// 0x099c: (CALL continued)
0x11, 0x00,	// 0x099e: RTS
///////////////////////////////////////////////
:FAIL
0x0d, 0x10,	// 0x09a0: OUT '\n'
0x0d, 0x46,	// 0x09a2: OUT 'F'
0x0d, 0x41,	// 0x09a4: OUT 'A'
0x0d, 0x49,	// 0x09a6: OUT 'I'
0x0d, 0x4c,	// 0x09a8: OUT 'L'
0x0d, 0x20,	// 0x09aa: OUT ' '
0x5b, 0xb4,	// 0x09ac: CALL :Test_duration
0x7b, 0x09,	// 0x09ae: (CALL continued)
0x10, 0x00,	// 0x09b0: (CALL continued)
0x01, 0x00,	// 0x09b2: BRK
///////////////////////////////////////////////
:Test_duration
0x7b, 0xe2,	// 0x09b4: LDA %DP, H, counter_base[1]
0x5b, 0x00,	// 0x09b6: LDA %DP, L, counter_base[0]

0x17, 0x01,	// 0x09b8: SDW R0, %DP, #1  // Latch Counter
// LDW R0, %DP, #5  // Print Byte4
// OUT R0, I
0x15, 0x04,	// 0x09ba: LDW R0, %DP, #4  // Print Byte3
0x28, 0x00,	// 0x09bc: OUT R0, I
0x55, 0x03,	// 0x09be: LDW R1, %DP, #3  // Print Byte2
0x28, 0x10,	// 0x09c0: OUT R1, I
0x95, 0x02,	// 0x09c2: LDW R2, %DP, #2  // Print Byte1
0x28, 0x20,	// 0x09c4: OUT R2, I
0x0d, 0x10,	// 0x09c6: OUT '\n'
0x11, 0x00,	// 0x09c8: RTS


