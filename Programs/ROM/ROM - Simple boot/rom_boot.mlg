///// Op Code 0x14,0x15 - LDW
//
//  This test relies on the test PUSH

:ldw_sdw
//Set PASS/FAIL flag
0x83, 0x00,	// 0x0722: LDR R2, #0   // FAIL flag

0xbb, 0x45,	// 0x0724: LDA %SP, H, stack_head[1]
0x9b, 0x00,	// 0x0726: LDA %SP, L, stack_head[0]
