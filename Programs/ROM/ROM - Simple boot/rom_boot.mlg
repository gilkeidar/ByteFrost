0x0d, 0x4f,	// 0x072e: OUT 'O'
0x0d, 0x70,	// 0x0730: OUT 'p'
0x2d, 0x14,	// 0x0732: OUT #0x14, I
0x0d, 0x2d,	// 0x0734: OUT '-'
0x2d, 0x15,	// 0x0736: OUT #0x15, I
0x0d, 0x3a,	// 0x0738: OUT ':'
