////////////////////////////////////////////////////////////
//	ROM Boot Code
//	Assumes:
//		1.	A BFSv1 filesystem is in use and the ByteFrost disk file used on the
//			disk has its boot sector correctly set up with first mutable code.

//	This ROM Boot Code does the following:
//	0. Run BIST
//  1.	Load the boot sector from disk into RAM (lowest possible pages)
//		*	The boot sector in disk is 2 KB (2 KB * (4 pages / 1 KB) = 8 pages)
//		*	ByteFrost memory address space:
//				First 8 KB are ROM		(pages 0 - 31)
//				Middle 48 KB are RAM	(pages 32 - 223)
//				Last 8 KB are MMIO		(pages 224 - 255)
//		->	Load pages 32 - 39 with the boot code
//	2.	Jump to the boot code.
////////////////////////////////////////////////////////////

.define	2 sdcard 			0xE000
.define	2 device1			0xE200
.define	2 device2			0xE400
.define	2 device3			0xE600
.define	2 device4			0xE800
.define	2 device5			0xEA00
.define	2 device6			0xEC00
.define	2 device7			0xEE00
.define 2 stack_address 	0xDF00  // Stack starts from DEFF downwards.
.define 2 stack_pointer 	0xDF00  // Resore SP from DF00-DF01 (different name for clarity)

//  0. BIST
0xbb, 0xdf,	// 0x0000: LDA %SP, H, stack_address[1]
0x9b, 0x00,	// 0x0002: LDA %SP, L, stack_address[0]
0x5b, 0x48,	// 0x0004: CALL :bist
0x7b, 0x00,	// 0x0006: (CALL continued)
0x10, 0x00,	// 0x0008: (CALL continued)


//	1.	Print "BFSv1 ROM BOOT\n"

0x0d, 0x10,	// 0x000a: OUT '\n'
0x0d, 0x42,	// 0x000c: OUT 'B'
0x0d, 0x6f,	// 0x000e: OUT 'o'
0x0d, 0x6f,	// 0x0010: OUT 'o'
0x0d, 0x74,	// 0x0012: OUT 't'
0x0d, 0x52,	// 0x0014: OUT 'R'
0x0d, 0x4f,	// 0x0016: OUT 'O'
0x0d, 0x4d,	// 0x0018: OUT 'M'
0x0d, 0x20,	// 0x001a: OUT ' '
0x0d, 0x76,	// 0x001c: OUT 'v'
0x0d, 0x31,	// 0x001e: OUT '1'
0x0d, 0x2e,	// 0x0020: OUT '.'
0x0d, 0x31,	// 0x0022: OUT '1'
0x0d, 0x10,	// 0x0024: OUT '\n'


//	2.	Copy first 8 pages from disk to pages 32 - 39

0x7b, 0xe0,	// 0x0026: LDA %DP, H, sdcard[1]
0x5b, 0x00,	// 0x0028: LDA %DP, L, sdcard[0]

//	Set SDCard command
//	Byte 0: Page
//	Byte 1: Sector High (3 lsb)
//	Byte 2: Sector Low
//	Byte 3: Go
//	SD Card Command format (16 bit command):
//	15	14	13	12	11	10-0
//	R/W	?	?	?	?	Sector ID

//	R0: i = 0 to 7 (page counter)
//	R1: SDCard command byte (0 - 3)
//	R2: SDCard command byte value

0x03, 0x00,	// 0x002a: LDR R0, #0		    //	for (i = 0; i < 8; i++)
:for_loop
0x83, 0x20,	// 0x002c: LDR R2, #32		    //	(Page = 32 + i)
0x82, 0x26,	// 0x002e: ADD R2, R2, R0
0x97, 0x00,	// 0x0030: SDW R2, %DP, #0     // Byte 0: Page = 32 + i
0x83, 0x00,	// 0x0032: LDR R2, #0x00	    //	Set Sector High = 0x00
0x97, 0x01,	// 0x0034: SDW R2, %DP, #1     // Byte 1: Sector High = 0
0x17, 0x02,	// 0x0036: SDW R0, %DP, #2     // Byte 2: Sector Low  = i
0x97, 0x03,	// 0x0038: SDW R2, %DP, #3     // Byte 3: Go (R2 is ignored)
0x06, 0x16,	// 0x003a: INC R0
0x13, 0x87,	// 0x003c: TST R0, #8
0x3b, 0x00,	// 0x003e: BNE :for_loop
0xe5, 0x2c,	// 0x0040: (BNE continued)

//	NOTE: Currently this cannot compile. Need to update the assembler
//	to allow for something like
//	:hardcodedLabelAddress = 2000
//	then
//	JMP :hardcodedLabelAddress
.define 2	RAM_START	0x2000
0x01, 0x00,	// 0x0042: BRK
0x3b, 0x20,	// 0x0044: JMP :__RAM_START__
0x05, 0x00,	// 0x0046: (JMP continued)



/////////////////////////////////////////////////////////////////
// BIST
:bist
// BIST is not using SP as a Stack Pointer, so it needs to store it and restore it at the end
0x7b, 0xdf,	// 0x0048: LDA %DP, H, stack_pointer[1]
0x5b, 0x00,	// 0x004a: LDA %DP, L, stack_pointer[0]
0xfa, 0x02,	// 0x004c: MAG R3, %SP, H
0x9a, 0x02,	// 0x004e: MAG R2, %SP, L
0xd7, 0x01,	// 0x0050: SDW R3, %DP, #1
0x97, 0x00,	// 0x0052: SDW R2, %DP, #0


0x0d, 0x10,	// 0x0054: OUT '\n'   // Space from previous run on the minicom
0x0d, 0x10,	// 0x0056: OUT '\n'
0x0d, 0x42,	// 0x0058: OUT 'B'
0x0d, 0x49,	// 0x005a: OUT 'I'
0x0d, 0x53,	// 0x005c: OUT 'S'
0x0d, 0x54,	// 0x005e: OUT 'T'
0x0d, 0x20,	// 0x0060: OUT ' '
0x0d, 0x76,	// 0x0062: OUT 'v'
0x0d, 0x33,	// 0x0064: OUT '3'
0x0d, 0x2e,	// 0x0066: OUT '.'
0x0d, 0x33,	// 0x0068: OUT '3'
0x0d, 0x10,	// 0x006a: OUT '\n'

/////////////////////////////////// Op Code 0x1B - LDA
// LDA is used in conditional /unconditional jumps, hence it is a foundational
// Op code that should be tested first

:lda_test

.define 2 address_1	0x1234
.define 2 address_2	0xFEDC

0x0d, 0x4f,	// 0x006c: OUT 'O'
0x0d, 0x70,	// 0x006e: OUT 'p'
0x2d, 0x1b,	// 0x0070: OUT #0x1B, I
0x0d, 0x3a,	// 0x0072: OUT ':'
0x0d, 0x20,	// 0x0074: OUT ' '
0x0d, 0x4c,	// 0x0076: OUT 'L'
0x0d, 0x44,	// 0x0078: OUT 'D'
0x0d, 0x41,	// 0x007a: OUT 'A'
0x0d, 0x10,	// 0x007c: OUT '\n'

// Test Addr 1
0x43, 0x12,	// 0x007e: LDR R1, address_1[1]
0x03, 0x34,	// 0x0080: LDR R0, address_1[0]

// DP
0x7b, 0x12,	// 0x0082: LDA %DP, H, address_1[1]
0x5b, 0x34,	// 0x0084: LDA %DP, L, address_1[0]
0xfa, 0x01,	// 0x0086: MAG R3, %DP, H
0x9a, 0x01,	// 0x0088: MAG R2, %DP, L

0x12, 0x77,	// 0x008a: TST R3, R1
0x3b, 0x01,	// 0x008c: BNE :print_bad_pointer
0xe5, 0x02,	// 0x008e: (BNE continued)
0x12, 0x27,	// 0x0090: TST R2, R0
0x3b, 0x01,	// 0x0092: BNE :print_bad_pointer
0xe5, 0x02,	// 0x0094: (BNE continued)

// BP
0xfb, 0x12,	// 0x0096: LDA %BP, H, address_1[1]
0xdb, 0x34,	// 0x0098: LDA %BP, L, address_1[0]
0xfa, 0x03,	// 0x009a: MAG R3, %BP, H
0x9a, 0x03,	// 0x009c: MAG R2, %BP, L

0x12, 0x77,	// 0x009e: TST R3, R1
0x3b, 0x01,	// 0x00a0: BNE :print_bad_pointer
0xe5, 0x02,	// 0x00a2: (BNE continued)
0x12, 0x27,	// 0x00a4: TST R2, R0
0x3b, 0x01,	// 0x00a6: BNE :print_bad_pointer
0xe5, 0x02,	// 0x00a8: (BNE continued)

// SP
0xbb, 0x12,	// 0x00aa: LDA %SP, H, address_1[1]
0x9b, 0x34,	// 0x00ac: LDA %SP, L, address_1[0]
0xfa, 0x02,	// 0x00ae: MAG R3, %SP, H
0x9a, 0x02,	// 0x00b0: MAG R2, %SP, L

0x12, 0x77,	// 0x00b2: TST R3, R1
0x3b, 0x01,	// 0x00b4: BNE :print_bad_pointer
0xe5, 0x02,	// 0x00b6: (BNE continued)
0x12, 0x27,	// 0x00b8: TST R2, R0
0x3b, 0x01,	// 0x00ba: BNE :print_bad_pointer
0xe5, 0x02,	// 0x00bc: (BNE continued)

// Test Addr 2
0x43, 0xfe,	// 0x00be: LDR R1, address_2[1]
0x03, 0xdc,	// 0x00c0: LDR R0, address_2[0]

// DP
0x7b, 0xfe,	// 0x00c2: LDA %DP, H, address_2[1]
0x5b, 0xdc,	// 0x00c4: LDA %DP, L, address_2[0]
0xfa, 0x01,	// 0x00c6: MAG R3, %DP, H
0x9a, 0x01,	// 0x00c8: MAG R2, %DP, L

0x12, 0x77,	// 0x00ca: TST R3, R1
0x3b, 0x01,	// 0x00cc: BNE :print_bad_pointer
0xe5, 0x02,	// 0x00ce: (BNE continued)
0x12, 0x27,	// 0x00d0: TST R2, R0
0x3b, 0x01,	// 0x00d2: BNE :print_bad_pointer
0xe5, 0x02,	// 0x00d4: (BNE continued)

// BP
0xfb, 0xfe,	// 0x00d6: LDA %BP, H, address_2[1]
0xdb, 0xdc,	// 0x00d8: LDA %BP, L, address_2[0]
0xfa, 0x03,	// 0x00da: MAG R3, %BP, H
0x9a, 0x03,	// 0x00dc: MAG R2, %BP, L

0x12, 0x77,	// 0x00de: TST R3, R1
0x3b, 0x01,	// 0x00e0: BNE :print_bad_pointer
0xe5, 0x02,	// 0x00e2: (BNE continued)
0x12, 0x27,	// 0x00e4: TST R2, R0
0x3b, 0x01,	// 0x00e6: BNE :print_bad_pointer
0xe5, 0x02,	// 0x00e8: (BNE continued)

// SP
0xbb, 0xfe,	// 0x00ea: LDA %SP, H, address_2[1]
0x9b, 0xdc,	// 0x00ec: LDA %SP, L, address_2[0]
0xfa, 0x02,	// 0x00ee: MAG R3, %SP, H
0x9a, 0x02,	// 0x00f0: MAG R2, %SP, L

0x12, 0x77,	// 0x00f2: TST R3, R1
0x3b, 0x01,	// 0x00f4: BNE :print_bad_pointer
0xe5, 0x02,	// 0x00f6: (BNE continued)
0x12, 0x27,	// 0x00f8: TST R2, R0
0x3b, 0x01,	// 0x00fa: BNE :print_bad_pointer
0xe5, 0x02,	// 0x00fc: (BNE continued)

0x3b, 0x01,	// 0x00fe: JMP :maa_test
0x05, 0x24,	// 0x0100: (JMP continued)

:print_bad_pointer
0x0d, 0x45,	// 0x0102: OUT 'E'
0x0d, 0x78,	// 0x0104: OUT 'x'
0x0d, 0x70,	// 0x0106: OUT 'p'
0x0d, 0x3a,	// 0x0108: OUT ':'
0x0d, 0x20,	// 0x010a: OUT ' '
0x28, 0x10,	// 0x010c: OUT R1, I
0x28, 0x00,	// 0x010e: OUT R0, I
0x0d, 0x10,	// 0x0110: OUT '\n'
0x0d, 0x47,	// 0x0112: OUT 'G'
0x0d, 0x6f,	// 0x0114: OUT 'o'
0x0d, 0x74,	// 0x0116: OUT 't'
0x0d, 0x3a,	// 0x0118: OUT ':'
0x0d, 0x20,	// 0x011a: OUT ' '
0x28, 0x30,	// 0x011c: OUT R3, I
0x28, 0x20,	// 0x011e: OUT R2, I
0x0d, 0x10,	// 0x0120: OUT '\n'
0x01, 0x00,	// 0x0122: BRK

/////////////////////////////////// Op Code 0x18-0x19 - MAA
// MAA is tested similarly to LDA
:maa_test

0x0d, 0x4f,	// 0x0124: OUT 'O'
0x0d, 0x70,	// 0x0126: OUT 'p'
0x2d, 0x18,	// 0x0128: OUT #0x18, I
0x0d, 0x2d,	// 0x012a: OUT '-'
0x2d, 0x19,	// 0x012c: OUT #0x19, I
0x0d, 0x3a,	// 0x012e: OUT ':'
0x0d, 0x20,	// 0x0130: OUT ' '
0x0d, 0x4d,	// 0x0132: OUT 'M'
0x0d, 0x41,	// 0x0134: OUT 'A'
0x0d, 0x41,	// 0x0136: OUT 'A'
0x0d, 0x10,	// 0x0138: OUT '\n'

.define 2 address_3	0x4567

0x43, 0x45,	// 0x013a: LDR R1, address_3[1]
0x03, 0x67,	// 0x013c: LDR R0, address_3[0]

// All transitions without PC: DP->BP->SP->DP->SP->SP->BP->BP->DP->DP
0x7b, 0x45,	// 0x013e: LDA %DP, H, address_3[1]
0x5b, 0x67,	// 0x0140: LDA %DP, L, address_3[0]
0xd9, 0x01,	// 0x0142: MAA %BP, %DP, #1   //address_3 + 1
0xb9, 0x02,	// 0x0144: MAA %SP, %BP, #2   //address_3 + 3
0x78, 0x03,	// 0x0146: MAA %DP, %SP, #3   //address_3 + 6
0x99, 0x04,	// 0x0148: MAA %SP, %DP, #4   //address_3 + 10
0xb8, 0x05,	// 0x014a: MAA %SP, %SP, #5   //address_3 + 15
0xf8, 0x06,	// 0x014c: MAA %BP, %SP, #6   //address_3 + 21
0xf9, 0x07,	// 0x014e: MAA %BP, %BP, #7   //address_3 + 28
0x79, 0x08,	// 0x0150: MAA %DP, %BP, #8   //address_3 + 36
0x59, 0x09,	// 0x0152: MAA %DP, %DP, #9   //address_3 + 45

// Now check:
//    SP = address_3 + 15
0x06, 0xf6,	// 0x0154: ADD R0, #0xF
0xfa, 0x02,	// 0x0156: MAG R3, %SP, H
0x9a, 0x02,	// 0x0158: MAG R2, %SP, L

0x12, 0x77,	// 0x015a: TST R3, R1
0x3b, 0x01,	// 0x015c: BNE :print_bad_pointer
0xe5, 0x02,	// 0x015e: (BNE continued)
0x12, 0x27,	// 0x0160: TST R2, R0
0x3b, 0x01,	// 0x0162: BNE :print_bad_pointer
0xe5, 0x02,	// 0x0164: (BNE continued)

//    BP = address_3 + 28
0x06, 0xd6,	// 0x0166: ADD R0, #0xD
0xfa, 0x03,	// 0x0168: MAG R3, %BP, H
0x9a, 0x03,	// 0x016a: MAG R2, %BP, L

0x12, 0x77,	// 0x016c: TST R3, R1
0x3b, 0x01,	// 0x016e: BNE :print_bad_pointer
0xe5, 0x02,	// 0x0170: (BNE continued)
0x12, 0x27,	// 0x0172: TST R2, R0
0x3b, 0x01,	// 0x0174: BNE :print_bad_pointer
0xe5, 0x02,	// 0x0176: (BNE continued)

//    DP = address_3 + 45
0x06, 0xa6,	// 0x0178: ADD R0, #0xA
0x06, 0x76,	// 0x017a: ADD R0, #0x7
0xfa, 0x01,	// 0x017c: MAG R3, %DP, H
0x9a, 0x01,	// 0x017e: MAG R2, %DP, L

0x12, 0x77,	// 0x0180: TST R3, R1
0x3b, 0x01,	// 0x0182: BNE :print_bad_pointer
0xe5, 0x02,	// 0x0184: (BNE continued)
0x12, 0x27,	// 0x0186: TST R2, R0
0x3b, 0x01,	// 0x0188: BNE :print_bad_pointer
0xe5, 0x02,	// 0x018a: (BNE continued)

0x3b, 0x01,	// 0x018c: JMP :nop_test
0x05, 0x90,	// 0x018e: (JMP continued)
//////////////////////////////////// Op Code 0x00 - NOP
:nop_test

0x0d, 0x4f,	// 0x0190: OUT 'O'
0x0d, 0x70,	// 0x0192: OUT 'p'
0x2d, 0x00,	// 0x0194: OUT #0, I
0x0d, 0x3a,	// 0x0196: OUT ':'
0x0d, 0x20,	// 0x0198: OUT ' '

// Test the number of clocks on NOPs

//	The interface of the 32-bit cycle counter is as follows:
//	Address		R/W Access?		Effect
//	0xE200		W				Reset 32-bit counter (to 0)
//	0xE201		W				Latch 32-bit counter (snapshot current value)
//	0xE202		R				Read counter byte 0 (LSB)
//	0xE203		R				Read counter byte 1
//	0xE204		R				Read counter byte 2
//	0xE205		R				Read counter byte 3 (MSB)
//	(Note that the counter value is accessed as a little-endian integer)
.define 2 counter_base	0xE200

// Work with BP instead of DP because DP is the default address and
// It is hard to observe when the address is with "intent"
0xfb, 0xe2,	// 0x019a: LDA %BP, H, counter_base[1]
0xdb, 0x00,	// 0x019c: LDA %BP, L, counter_base[0]
0x37, 0x00,	// 0x019e: SDW R0, %BP, #0     // Reset Counter

0x00, 0x00,	// 0x01a0: NOP
0x00, 0x00,	// 0x01a2: NOP
0x00, 0x00,	// 0x01a4: NOP
0x00, 0x00,	// 0x01a6: NOP
0x00, 0x00,	// 0x01a8: NOP   // Time 5 NOPS. Counter = 5 * 2 + 4 = 14 (0xE)

0x37, 0x01,	// 0x01aa: SDW R0, %BP, #1  // Latch Counter
// LDW R0, %DP, #5  // Print Byte4
// OUT R0, I
0x35, 0x04,	// 0x01ac: LDW R0, %BP, #4  // Print Byte3
0x28, 0x00,	// 0x01ae: OUT R0, I
0x75, 0x03,	// 0x01b0: LDW R1, %BP, #3  // Print Byte2
0x28, 0x10,	// 0x01b2: OUT R1, I
0xb5, 0x02,	// 0x01b4: LDW R2, %BP, #2  // Print Byte1
0x28, 0x20,	// 0x01b6: OUT R2, I
0xc3, 0x0e,	// 0x01b8: LDR R3, #0xE
0x12, 0xe7,	// 0x01ba: TST R2, R3
0x3b, 0x09,	// 0x01bc: BNE :FAIL
0xe5, 0xa2,	// 0x01be: (BNE continued)

0x0d, 0x20,	// 0x01c0: OUT ' '

0x37, 0x00,	// 0x01c2: SDW R0, %BP, #0     // Reset Counter

0x00, 0x00,	// 0x01c4: NOP
0x00, 0x00,	// 0x01c6: NOP
0x00, 0x00,	// 0x01c8: NOP
0x00, 0x00,	// 0x01ca: NOP
0x00, 0x00,	// 0x01cc: NOP   // Time 5 NOPS
0x00, 0x00,	// 0x01ce: NOP
0x00, 0x00,	// 0x01d0: NOP
0x00, 0x00,	// 0x01d2: NOP
0x00, 0x00,	// 0x01d4: NOP
0x00, 0x00,	// 0x01d6: NOP   // Time 10 NOPS Counter = 10 * 2 + 4 = 24 (0x18)


0x37, 0x01,	// 0x01d8: SDW R0, %BP, #1  // Latch Counter
// LDW R0, %DP, #5  // Print Byte4
// OUT R0, I
0x35, 0x04,	// 0x01da: LDW R0, %BP, #4  // Print Byte3
0x28, 0x00,	// 0x01dc: OUT R0, I
0x75, 0x03,	// 0x01de: LDW R1, %BP, #3  // Print Byte2
0x28, 0x10,	// 0x01e0: OUT R1, I
0xb5, 0x02,	// 0x01e2: LDW R2, %BP, #2  // Print Byte1
0x28, 0x20,	// 0x01e4: OUT R2, I
0xc3, 0x18,	// 0x01e6: LDR R3, #0x18
0x12, 0xe7,	// 0x01e8: TST R2, R3
0x3b, 0x09,	// 0x01ea: BNE :FAIL
0xe5, 0xa2,	// 0x01ec: (BNE continued)

0x0d, 0x10,	// 0x01ee: OUT '\n'
////////////////////////////////////

//////////////////////////////////// Op Code 0x01 - BRK
0x0d, 0x4f,	// 0x01f0: OUT 'O'
0x0d, 0x70,	// 0x01f2: OUT 'p'
0x2d, 0x01,	// 0x01f4: OUT #1, I
0x0d, 0x3a,	// 0x01f6: OUT ':'
0x0d, 0x20,	// 0x01f8: OUT ' '
0x0d, 0x42,	// 0x01fa: OUT 'B'
0x0d, 0x52,	// 0x01fc: OUT 'R'
0x0d, 0x4b,	// 0x01fe: OUT 'K'
0x0d, 0x2d,	// 0x0200: OUT '-'
0x0d, 0x53,	// 0x0202: OUT 'S'
0x0d, 0x4b,	// 0x0204: OUT 'K'
0x0d, 0x49,	// 0x0206: OUT 'I'
0x0d, 0x50,	// 0x0208: OUT 'P'
0x0d, 0x10,	// 0x020a: OUT '\n'
////////////////////////////////////

//////////////////////////////////// Op Code 0x02 - ALU
0x0d, 0x4f,	// 0x020c: OUT 'O'
0x0d, 0x70,	// 0x020e: OUT 'p'
0x2d, 0x02,	// 0x0210: OUT #2, I
0x0d, 0x3a,	// 0x0212: OUT ':'
0x0d, 0x20,	// 0x0214: OUT ' '
0x0d, 0x41,	// 0x0216: OUT 'A'
0x0d, 0x4c,	// 0x0218: OUT 'L'
0x0d, 0x55,	// 0x021a: OUT 'U'
0x0d, 0x10,	// 0x021c: OUT '\n'

0x03, 0x27,	// 0x021e: LDR R0, #0x27       // Don't change!
0x43, 0xe6,	// 0x0220: LDR R1, #0xE6       // Don't change!

////////////////////////////////////////////

// 0 -	OR

0x0d, 0x4f,	// 0x0222: OUT 'O'
0x0d, 0x52,	// 0x0224: OUT 'R'
0x0d, 0x2c,	// 0x0226: OUT ','
0x82, 0x10,	// 0x0228: OR  R2, R1, R0
0xc3, 0xe7,	// 0x022a: LDR R3, #0xE7
0x12, 0xe7,	// 0x022c: TST R2, R3
0x3b, 0x09,	// 0x022e: BNE :FAIL
0xe5, 0xa2,	// 0x0230: (BNE continued)

////////////////////////////////////////////

// 1 - 	AND

0x0d, 0x41,	// 0x0232: OUT 'A'
0x0d, 0x4e,	// 0x0234: OUT 'N'
0x0d, 0x44,	// 0x0236: OUT 'D'
0x0d, 0x2c,	// 0x0238: OUT ','
0x82, 0x12,	// 0x023a: AND  R2, R1, R0
0xc3, 0x26,	// 0x023c: LDR R3, #0x26
0x12, 0xe7,	// 0x023e: TST R2, R3
0x3b, 0x09,	// 0x0240: BNE :FAIL
0xe5, 0xa2,	// 0x0242: (BNE continued)

////////////////////////////////////////////

// 2 - 	XOR

0x0d, 0x58,	// 0x0244: OUT 'X'
0x0d, 0x4f,	// 0x0246: OUT 'O'
0x0d, 0x52,	// 0x0248: OUT 'R'
0x0d, 0x2c,	// 0x024a: OUT ','
0x82, 0x14,	// 0x024c: XOR  R2, R1, R0
0xc3, 0xc1,	// 0x024e: LDR R3, #0xC1
0x12, 0xe7,	// 0x0250: TST R2, R3
0x3b, 0x09,	// 0x0252: BNE :FAIL
0xe5, 0xa2,	// 0x0254: (BNE continued)

////////////////////////////////////////////

// 2.1- NOT

0x0d, 0x4e,	// 0x0256: OUT 'N'
0x0d, 0x4f,	// 0x0258: OUT 'O'
0x0d, 0x54,	// 0x025a: OUT 'T'
0x0d, 0x2c,	// 0x025c: OUT ','
0x82, 0x05,	// 0x025e: NOT  R2, R0
0xc3, 0xd8,	// 0x0260: LDR R3, #0xD8
0x12, 0xe7,	// 0x0262: TST R2, R3
0x3b, 0x09,	// 0x0264: BNE :FAIL
0xe5, 0xa2,	// 0x0266: (BNE continued)

////////////////////////////////////////////

// 3 - 	ADD
// 7 -  ADC	- C = A + B + Cin

0x0d, 0x10,	// 0x0268: OUT '\n'
0x0d, 0x41,	// 0x026a: OUT 'A'
0x0d, 0x44,	// 0x026c: OUT 'D'
0x0d, 0x44,	// 0x026e: OUT 'D'
0x0d, 0x2d,	// 0x0270: OUT '-'
0x0d, 0x41,	// 0x0272: OUT 'A'
0x0d, 0x44,	// 0x0274: OUT 'D'
0x0d, 0x43,	// 0x0276: OUT 'C'

0x82, 0x16,	// 0x0278: ADD  R2, R1, R0   // 10D = E6 + 27
0x3b, 0x09,	// 0x027a: BCC :FAIL         // Fail if Cary is not set
0xc5, 0xa2,	// 0x027c: (BCC continued)
0x0d, 0x2e,	// 0x027e: OUT '.'           // Pass 1 check
0xc2, 0x4e,	// 0x0280: ADC  R3, R0, R1   // Test the Carry  (0x10E0D = 27E6 + E627)
0x3b, 0x09,	// 0x0282: BCC :FAIL         // Fail if Cary is not set
0xc5, 0xa2,	// 0x0284: (BCC continued)
0x0d, 0x2e,	// 0x0286: OUT '.'           // Pass 2 check

0x03, 0x0e,	// 0x0288: LDR R0, #0x0E
0x12, 0xc7,	// 0x028a: TST R0, R3
0x3b, 0x09,	// 0x028c: BNE :FAIL
0xe5, 0xa2,	// 0x028e: (BNE continued)
0x0d, 0x2e,	// 0x0290: OUT '.'        // Pass 3 check
0x03, 0x0d,	// 0x0292: LDR R0, #0x0D
0x12, 0x87,	// 0x0294: TST R0, R2
0x3b, 0x09,	// 0x0296: BNE :FAIL
0xe5, 0xa2,	// 0x0298: (BNE continued)
0x0d, 0x2e,	// 0x029a: OUT '.'        // Pass 4 check
0x03, 0x27,	// 0x029c: LDR R0, #0x27     // Restore Settings

////////////////////////////////////////////

// 3.1- SUB
// 7.1- SBC - C = A - B - NOT(Cin)

0x0d, 0x10,	// 0x029e: OUT '\n'
0x0d, 0x53,	// 0x02a0: OUT 'S'
0x0d, 0x55,	// 0x02a2: OUT 'U'
0x0d, 0x42,	// 0x02a4: OUT 'B'
0x0d, 0x2d,	// 0x02a6: OUT '-'
0x0d, 0x53,	// 0x02a8: OUT 'S'
0x0d, 0x42,	// 0x02aa: OUT 'B'
0x0d, 0x43,	// 0x02ac: OUT 'C'

0x82, 0x17,	// 0x02ae: SUB  R2, R1, R0   // BF = E6 - 27
0x3b, 0x09,	// 0x02b0: BCC :FAIL         // Borrow is inverse of Carry. No Borrow, so Carry is set. Fail if Cary is not set
0xc5, 0xa2,	// 0x02b2: (BCC continued)
0x0d, 0x2e,	// 0x02b4: OUT '.'        // Pass 1 check
0xc2, 0x0f,	// 0x02b6: SBC  R3, R0, R0   // Test the Borrow (0x00BF = 0x27E6 - 0x2727)
0xd3, 0x07,	// 0x02b8: TST R3, #0x00
0x3b, 0x09,	// 0x02ba: BNE :FAIL
0xe5, 0xa2,	// 0x02bc: (BNE continued)
0x0d, 0x2e,	// 0x02be: OUT '.'        // Pass 2 check
0xc3, 0xbf,	// 0x02c0: LDR R3, #0xBF
0x12, 0xe7,	// 0x02c2: TST R2, R3
0x3b, 0x09,	// 0x02c4: BNE :FAIL
0xe5, 0xa2,	// 0x02c6: (BNE continued)
0x0d, 0x2e,	// 0x02c8: OUT '.'        // Pass 3 check
// Now repeat bu with Borrow (0xFF41 = 0x2727 - 0x27E6)
0x82, 0x47,	// 0x02ca: SUB  R2, R0, R1   // 41 + Borrow = 27 - E6
0x3b, 0x09,	// 0x02cc: BCS :FAIL         // Borrow is inverse of Carry. Borrow is needed so Carry is clear. Fail if Cary is not clear
0x45, 0xa2,	// 0x02ce: (BCS continued)
0x0d, 0x2e,	// 0x02d0: OUT '.'        // Pass 4 check
0xc2, 0x0f,	// 0x02d2: SBC  R3, R0, R0   // Test the Borrow (0xFF41 = 0x2727 - 0x27E6)
0xc6, 0x16,	// 0x02d4: INC R3            // Using Borrow, R3 should be 0xFF instead of 0x0
0xd3, 0x07,	// 0x02d6: TST R3, #0x0
0x3b, 0x09,	// 0x02d8: BNE :FAIL
0xe5, 0xa2,	// 0x02da: (BNE continued)
0x0d, 0x2e,	// 0x02dc: OUT '.'        // Pass 5 check
0xc3, 0x41,	// 0x02de: LDR R3, #0x41
0x12, 0xe7,	// 0x02e0: TST R2, R3
0x3b, 0x09,	// 0x02e2: BNE :FAIL
0xe5, 0xa2,	// 0x02e4: (BNE continued)
0x0d, 0x2e,	// 0x02e6: OUT '.'        // Pass 6 check
0x0d, 0x10,	// 0x02e8: OUT '\n'

////////////////////////////////////////////

// 4 - 	ASL - Shift Left (msb goes to Cout, lsb gets 0)

0x0d, 0x41,	// 0x02ea: OUT 'A'
0x0d, 0x53,	// 0x02ec: OUT 'S'
0x0d, 0x4c,	// 0x02ee: OUT 'L'
0x0d, 0x2c,	// 0x02f0: OUT ','

0x82, 0x18,	// 0x02f2: ASL R2, R1   // E6 -> CC + C
0xc3, 0xcc,	// 0x02f4: LDR R3, #0xCC
0x12, 0xe7,	// 0x02f6: TST R2, R3
0x3b, 0x09,	// 0x02f8: BNE :FAIL
0xe5, 0xa2,	// 0x02fa: (BNE continued)
0x82, 0x28,	// 0x02fc: ASL R2, R2   // CC -> 98 + C
0xc3, 0x98,	// 0x02fe: LDR R3, #0x98
0x12, 0xe7,	// 0x0300: TST R2, R3
0x3b, 0x09,	// 0x0302: BNE :FAIL
0xe5, 0xa2,	// 0x0304: (BNE continued)
0x82, 0x28,	// 0x0306: ASL R2, R2   // 98 -> 30 + C
0xc3, 0x30,	// 0x0308: LDR R3, #0x30
0x12, 0xe7,	// 0x030a: TST R2, R3
0x3b, 0x09,	// 0x030c: BNE :FAIL
0xe5, 0xa2,	// 0x030e: (BNE continued)
0x82, 0x28,	// 0x0310: ASL R2, R2   // 30 -> 60
0xc3, 0x60,	// 0x0312: LDR R3, #0x60
0x12, 0xe7,	// 0x0314: TST R2, R3
0x3b, 0x09,	// 0x0316: BNE :FAIL
0xe5, 0xa2,	// 0x0318: (BNE continued)

////////////////////////////////////////////

// 4.1- ROL - Rotate Left (msb goes to Cout, lsb gets Cin)

0x0d, 0x52,	// 0x031a: OUT 'R'
0x0d, 0x4f,	// 0x031c: OUT 'O'
0x0d, 0x4c,	// 0x031e: OUT 'L'
0x0d, 0x2c,	// 0x0320: OUT ','

// Clear Carry
0xc3, 0x00,	// 0x0322: LDR R3, #0x00
0xc2, 0x39,	// 0x0324: ROL R3, R3

0x82, 0x19,	// 0x0326: ROL R2, R1   // E6     -> CC + C
0x3b, 0x09,	// 0x0328: BCC :FAIL
0xc5, 0xa2,	// 0x032a: (BCC continued)
0x82, 0x29,	// 0x032c: ROL R2, R2   // CC + C -> 99 + C
0x3b, 0x09,	// 0x032e: BCC :FAIL
0xc5, 0xa2,	// 0x0330: (BCC continued)
0x82, 0x29,	// 0x0332: ROL R2, R2   // 99 + C -> 33 + C
0x3b, 0x09,	// 0x0334: BCC :FAIL
0xc5, 0xa2,	// 0x0336: (BCC continued)
0x82, 0x29,	// 0x0338: ROL R2, R2   // 33 + C -> 67
0x3b, 0x09,	// 0x033a: BCS :FAIL
0x45, 0xa2,	// 0x033c: (BCS continued)
0x82, 0x29,	// 0x033e: ROL R2, R2   // 67     -> CE
0xc3, 0xce,	// 0x0340: LDR R3, #0xCE
0x12, 0xe7,	// 0x0342: TST R2, R3
0x3b, 0x09,	// 0x0344: BNE :FAIL
0xe5, 0xa2,	// 0x0346: (BNE continued)

////////////////////////////////////////////

// 5 -  LSR - Logic Shift Right (msb gets 0, lsb goes to Cout)
0x0d, 0x4c,	// 0x0348: OUT 'L'
0x0d, 0x53,	// 0x034a: OUT 'S'
0x0d, 0x52,	// 0x034c: OUT 'R'
0x0d, 0x2c,	// 0x034e: OUT ','

0x82, 0x1a,	// 0x0350: LSR R2, R1   // E6     -> 73
0x3b, 0x09,	// 0x0352: BCS :FAIL
0x45, 0xa2,	// 0x0354: (BCS continued)
0x82, 0x2a,	// 0x0356: LSR R2, R2   // 73     -> 39 + C
0x3b, 0x09,	// 0x0358: BCC :FAIL
0xc5, 0xa2,	// 0x035a: (BCC continued)
0x82, 0x2a,	// 0x035c: LSR R2, R2   // 39 + C -> 1C + C
0x3b, 0x09,	// 0x035e: BCC :FAIL
0xc5, 0xa2,	// 0x0360: (BCC continued)
0x82, 0x2a,	// 0x0362: LSR R2, R2   // 1C + C -> 0E
0x3b, 0x09,	// 0x0364: BCS :FAIL
0x45, 0xa2,	// 0x0366: (BCS continued)
0x82, 0x2a,	// 0x0368: LSR R2, R2   // 0E     -> 07
0xc3, 0x07,	// 0x036a: LDR R3, #0x07
0x12, 0xe7,	// 0x036c: TST R2, R3
0x3b, 0x09,	// 0x036e: BNE :FAIL
0xe5, 0xa2,	// 0x0370: (BNE continued)

////////////////////////////////////////////

// 5.1- ASR - Arithmetic Shift Right (msb sign-extended, lsb goes to Cout)
0x0d, 0x41,	// 0x0372: OUT 'A'
0x0d, 0x53,	// 0x0374: OUT 'S'
0x0d, 0x52,	// 0x0376: OUT 'R'
0x0d, 0x2c,	// 0x0378: OUT ','

0x82, 0x1b,	// 0x037a: ASR R2, R1   // E6     -> F3
0x3b, 0x09,	// 0x037c: BCS :FAIL
0x45, 0xa2,	// 0x037e: (BCS continued)
0x82, 0x2b,	// 0x0380: ASR R2, R2   // F3     -> F9 + C
0x3b, 0x09,	// 0x0382: BCC :FAIL
0xc5, 0xa2,	// 0x0384: (BCC continued)
0x82, 0x2b,	// 0x0386: ASR R2, R2   // F9 + C -> FC + C
0x3b, 0x09,	// 0x0388: BCC :FAIL
0xc5, 0xa2,	// 0x038a: (BCC continued)
0x82, 0x2b,	// 0x038c: ASR R2, R2   // FC + C -> FE
0x3b, 0x09,	// 0x038e: BCS :FAIL
0x45, 0xa2,	// 0x0390: (BCS continued)
0xc3, 0xfe,	// 0x0392: LDR R3, #0xFE
0x12, 0xe7,	// 0x0394: TST R2, R3
0x3b, 0x09,	// 0x0396: BNE :FAIL
0xe5, 0xa2,	// 0x0398: (BNE continued)

////////////////////////////////////////////

// 6 -  ROR - Rotate Right Cin -> Reg -> Cout
0x0d, 0x52,	// 0x039a: OUT 'R'
0x0d, 0x4f,	// 0x039c: OUT 'O'
0x0d, 0x52,	// 0x039e: OUT 'R'

// Clear Carry
0xc3, 0x00,	// 0x03a0: LDR R3, #0x00
0xc2, 0x3c,	// 0x03a2: ROR R3, R3

0x82, 0x1c,	// 0x03a4: ROR R2, R1   // E6     -> 73
0x3b, 0x09,	// 0x03a6: BCS :FAIL
0x45, 0xa2,	// 0x03a8: (BCS continued)
0x82, 0x2c,	// 0x03aa: ROR R2, R2   // 73     -> 39 + C
0x3b, 0x09,	// 0x03ac: BCC :FAIL
0xc5, 0xa2,	// 0x03ae: (BCC continued)
0x82, 0x2c,	// 0x03b0: ROR R2, R2   // 39 + C -> 9C + C
0x3b, 0x09,	// 0x03b2: BCC :FAIL
0xc5, 0xa2,	// 0x03b4: (BCC continued)
0x82, 0x2c,	// 0x03b6: ROR R2, R2   // 9C + C -> CE
0x3b, 0x09,	// 0x03b8: BCS :FAIL
0x45, 0xa2,	// 0x03ba: (BCS continued)
0x82, 0x2c,	// 0x03bc: ROR R2, R2   // CE     -> 67
0xc3, 0x67,	// 0x03be: LDR R3, #0x67
0x12, 0xe7,	// 0x03c0: TST R2, R3
0x3b, 0x09,	// 0x03c2: BNE :FAIL
0xe5, 0xa2,	// 0x03c4: (BNE continued)
0x0d, 0x10,	// 0x03c6: OUT '\n'

//////////////////////////////////// Op Code 0x03 - LDR
0x0d, 0x4f,	// 0x03c8: OUT 'O'
0x0d, 0x70,	// 0x03ca: OUT 'p'
0x2d, 0x03,	// 0x03cc: OUT #3, I
0x0d, 0x3a,	// 0x03ce: OUT ':'
0x0d, 0x20,	// 0x03d0: OUT ' '
0x0d, 0x4c,	// 0x03d2: OUT 'L'
0x0d, 0x44,	// 0x03d4: OUT 'D'
0x0d, 0x52,	// 0x03d6: OUT 'R'
0x0d, 0x2d,	// 0x03d8: OUT '-'
0x0d, 0x53,	// 0x03da: OUT 'S'
0x0d, 0x4b,	// 0x03dc: OUT 'K'
0x0d, 0x49,	// 0x03de: OUT 'I'
0x0d, 0x50,	// 0x03e0: OUT 'P'
0x0d, 0x10,	// 0x03e2: OUT '\n'

//////////////////////////////////// Op Code 0x04 - MOV
0x0d, 0x4f,	// 0x03e4: OUT 'O'
0x0d, 0x70,	// 0x03e6: OUT 'p'
0x2d, 0x04,	// 0x03e8: OUT #4, I
0x0d, 0x3a,	// 0x03ea: OUT ':'
0x0d, 0x20,	// 0x03ec: OUT ' '
0x0d, 0x4d,	// 0x03ee: OUT 'M'
0x0d, 0x4f,	// 0x03f0: OUT 'O'
0x0d, 0x76,	// 0x03f2: OUT 'v'

0x43, 0xa5,	// 0x03f4: LDR R1, #0xA5
0x84, 0x10,	// 0x03f6: MOV R2, R1
0xc4, 0x20,	// 0x03f8: MOV R3, R2
0x04, 0x30,	// 0x03fa: MOV R0, R3

0x43, 0x5a,	// 0x03fc: LDR R1, #0x5A

0x12, 0x97,	// 0x03fe: TST R1, R2
0x3b, 0x09,	// 0x0400: BEQ :FAIL
0x65, 0xa2,	// 0x0402: (BEQ continued)
0x84, 0x10,	// 0x0404: MOV R2, R1
0x12, 0x97,	// 0x0406: TST R1, R2
0x3b, 0x09,	// 0x0408: BNE :FAIL
0xe5, 0xa2,	// 0x040a: (BNE continued)

0x12, 0xe7,	// 0x040c: TST R2, R3
0x3b, 0x09,	// 0x040e: BEQ :FAIL
0x65, 0xa2,	// 0x0410: (BEQ continued)
0xc4, 0x20,	// 0x0412: MOV R3, R2
0x12, 0xe7,	// 0x0414: TST R2, R3
0x3b, 0x09,	// 0x0416: BNE :FAIL
0xe5, 0xa2,	// 0x0418: (BNE continued)

0x12, 0x37,	// 0x041a: TST R3, R0
0x3b, 0x09,	// 0x041c: BEQ :FAIL
0x65, 0xa2,	// 0x041e: (BEQ continued)
0x04, 0x30,	// 0x0420: MOV R0, R3
0x12, 0x37,	// 0x0422: TST R3, R0
0x3b, 0x09,	// 0x0424: BNE :FAIL
0xe5, 0xa2,	// 0x0426: (BNE continued)

0x0d, 0x10,	// 0x0428: OUT '\n'

//////////////////////////////////// Op Code 0x05 - BRANCH ABS
0x0d, 0x4f,	// 0x042a: OUT 'O'
0x0d, 0x70,	// 0x042c: OUT 'p'
0x2d, 0x05,	// 0x042e: OUT #5, I
0x0d, 0x3a,	// 0x0430: OUT ':'
0x0d, 0x20,	// 0x0432: OUT ' '
0x0d, 0x42,	// 0x0434: OUT 'B'
0x0d, 0x52,	// 0x0436: OUT 'R'
0x0d, 0x41,	// 0x0438: OUT 'A'
0x0d, 0x4e,	// 0x043a: OUT 'N'
0x0d, 0x43,	// 0x043c: OUT 'C'
0x0d, 0x48,	// 0x043e: OUT 'H'
0x0d, 0x20,	// 0x0440: OUT ' '
0x0d, 0x41,	// 0x0442: OUT 'A'
0x0d, 0x42,	// 0x0444: OUT 'B'
0x0d, 0x53,	// 0x0446: OUT 'S'
0x0d, 0x10,	// 0x0448: OUT '\n'

//	The conditional branches are tested twice - once where the branch
//	should be taken, and once where it should not be taken.

//	1.	JMP
0x0d, 0x4a,	// 0x044a: OUT 'J'
0x0d, 0x4d,	// 0x044c: OUT 'M'
0x0d, 0x50,	// 0x044e: OUT 'P'

0x3b, 0x04,	// 0x0450: JMP :JMP_PASS
0x05, 0x58,	// 0x0452: (JMP continued)
0x3b, 0x09,	// 0x0454: JMP :FAIL
0x05, 0xa2,	// 0x0456: (JMP continued)

:JMP_PASS

//	2.	BMI (Branch on Minus - Negative flag must be set)
0x0d, 0x2c,	// 0x0458: OUT ','
0x0d, 0x42,	// 0x045a: OUT 'B'
0x0d, 0x4d,	// 0x045c: OUT 'M'
0x0d, 0x49,	// 0x045e: OUT 'I'

//	Branch should not be taken.
0x03, 0x04,	// 0x0460: LDR R0, #4
0x43, 0x05,	// 0x0462: LDR R1, #5

0x12, 0x17,	// 0x0464: TST R1, R0	//	R1 - R0 = 1 > 0, minus flag not set.
0x3b, 0x09,	// 0x0466: BMI :FAIL
0x25, 0xa2,	// 0x0468: (BMI continued)

//	Branch should be taken.
0x12, 0x47,	// 0x046a: TST R0, R1	//	R0 - R1 = -1 < 0, minus flag is set.
0x3b, 0x04,	// 0x046c: BMI :BMI_PASS
0x25, 0x74,	// 0x046e: (BMI continued)
0x3b, 0x09,	// 0x0470: JMP :FAIL
0x05, 0xa2,	// 0x0472: (JMP continued)

:BMI_PASS

//	3.	BCS (Branch Carry Set - Carry flag must be set)
0x0d, 0x2c,	// 0x0474: OUT ','
0x0d, 0x42,	// 0x0476: OUT 'B'
0x0d, 0x43,	// 0x0478: OUT 'C'
0x0d, 0x53,	// 0x047a: OUT 'S'

//	Branch should not be taken.
0x03, 0x40,	// 0x047c: LDR R0, #0x40
0x02, 0x08,	// 0x047e: ASL R0, R0	//	R0 = 0x80, Cout = 0 -> Carry flag is not set.
0x3b, 0x09,	// 0x0480: BCS :FAIL
0x45, 0xa2,	// 0x0482: (BCS continued)

//	Branch should be taken.
0x02, 0x08,	// 0x0484: ASL R0, R0	//	R0 = 0x00, Cout = 1 -> Carry flag is set.
0x3b, 0x04,	// 0x0486: BCS :BCS_PASS
0x45, 0x8e,	// 0x0488: (BCS continued)
0x3b, 0x09,	// 0x048a: JMP :FAIL
0x05, 0xa2,	// 0x048c: (JMP continued)

:BCS_PASS

//	4.	BEQ (Branch Equal - Zero flag must be set)
0x0d, 0x2c,	// 0x048e: OUT ','
0x0d, 0x42,	// 0x0490: OUT 'B'
0x0d, 0x45,	// 0x0492: OUT 'E'
0x0d, 0x51,	// 0x0494: OUT 'Q'

//	Branch should not be taken.
0x03, 0x56,	// 0x0496: LDR R0, #0x56
0x43, 0x55,	// 0x0498: LDR R1, #0x55

0x12, 0x17,	// 0x049a: TST R1, R0
0x3b, 0x09,	// 0x049c: BEQ :FAIL
0x65, 0xa2,	// 0x049e: (BEQ continued)

//	Branch should be taken.
0x46, 0x16,	// 0x04a0: INC R1
0x12, 0x17,	// 0x04a2: TST R1, R0
0x3b, 0x04,	// 0x04a4: BEQ :BEQ_PASS
0x65, 0xac,	// 0x04a6: (BEQ continued)
0x3b, 0x09,	// 0x04a8: JMP :FAIL
0x05, 0xa2,	// 0x04aa: (JMP continued)

:BEQ_PASS

//	5.	BPL (Branch on Plus - Negative flag must not be set (really, should be Branch on Non-Negative))
0x0d, 0x2c,	// 0x04ac: OUT ','
0x0d, 0x42,	// 0x04ae: OUT 'B'
0x0d, 0x50,	// 0x04b0: OUT 'P'
0x0d, 0x4c,	// 0x04b2: OUT 'L'

//	Branch should not be taken.
0x03, 0x55,	// 0x04b4: LDR R0, #0x55
0x43, 0x56,	// 0x04b6: LDR R1, #0x56

0x12, 0x47,	// 0x04b8: TST R0, R1	//	R0 - R1 = -1 -> Negative flag is set.
0x3b, 0x09,	// 0x04ba: BPL :FAIL
0xa5, 0xa2,	// 0x04bc: (BPL continued)

//	Branch should be taken.
0x12, 0x17,	// 0x04be: TST R1, R0	//	R1 - R0 = 1 -> non-negative (negative flag not set).
0x3b, 0x04,	// 0x04c0: BPL :BPL_PASS1
0xa5, 0xc8,	// 0x04c2: (BPL continued)
0x3b, 0x09,	// 0x04c4: JMP :FAIL
0x05, 0xa2,	// 0x04c6: (JMP continued)

:BPL_PASS1

//	Branch should be taken
0x12, 0x07,	// 0x04c8: TST R0, R0	//	R0 - R0 = 0 -> non-negative (negative flag not set).
0x3b, 0x04,	// 0x04ca: BPL :BPL_PASS2
0xa5, 0xd2,	// 0x04cc: (BPL continued)
0x3b, 0x09,	// 0x04ce: JMP :FAIL
0x05, 0xa2,	// 0x04d0: (JMP continued)

:BPL_PASS2

//	6.	BCC (Branch Carry Clear - Carry flag must not be set)
0x0d, 0x2c,	// 0x04d2: OUT ','
0x0d, 0x42,	// 0x04d4: OUT 'B'
0x0d, 0x43,	// 0x04d6: OUT 'C'
0x0d, 0x43,	// 0x04d8: OUT 'C'

//	Branch should not be taken.
0x03, 0x05,	// 0x04da: LDR R0, #0x05
0x02, 0x0b,	// 0x04dc: ASR R0, R0	//	R0 = 0x02, Cout = 1

0x3b, 0x09,	// 0x04de: BCC :FAIL
0xc5, 0xa2,	// 0x04e0: (BCC continued)

//	Branch should be taken.
0x02, 0x0b,	// 0x04e2: ASR R0, R0	//	R0 = 0x01, Cout = 0
0x3b, 0x04,	// 0x04e4: BCC :BCC_PASS
0xc5, 0xec,	// 0x04e6: (BCC continued)
0x3b, 0x09,	// 0x04e8: JMP :FAIL
0x05, 0xa2,	// 0x04ea: (JMP continued)

:BCC_PASS

//	7.	BNE (Branch Not Equal - Zero flag must not be set)
0x0d, 0x2c,	// 0x04ec: OUT ','
0x0d, 0x42,	// 0x04ee: OUT 'B'
0x0d, 0x4e,	// 0x04f0: OUT 'N'
0x0d, 0x45,	// 0x04f2: OUT 'E'

//	Branch should not be taken.
0x03, 0x47,	// 0x04f4: LDR R0, #0x47
0x43, 0x47,	// 0x04f6: LDR R1, #0x47

0x12, 0x17,	// 0x04f8: TST R1, R0
0x3b, 0x09,	// 0x04fa: BNE :FAIL
0xe5, 0xa2,	// 0x04fc: (BNE continued)

//	Branch should be taken.
0x46, 0x17,	// 0x04fe: DEC R1
0x12, 0x17,	// 0x0500: TST R1, R0
0x3b, 0x05,	// 0x0502: BNE :BNE_PASS
0xe5, 0x0a,	// 0x0504: (BNE continued)
0x3b, 0x09,	// 0x0506: JMP :FAIL
0x05, 0xa2,	// 0x0508: (JMP continued)
:BNE_PASS

//////////////////////////////////// Op Code 0x06 - ALU Immediate
// The immediate is only 4 bit sign extended, so the range is [-8 .. 7]
// Only two parameter operations are applicable
0x0d, 0x10,	// 0x050a: OUT '\n'
0x0d, 0x4f,	// 0x050c: OUT 'O'
0x0d, 0x70,	// 0x050e: OUT 'p'
0x2d, 0x06,	// 0x0510: OUT #6, I
0x0d, 0x3a,	// 0x0512: OUT ':'
0x0d, 0x20,	// 0x0514: OUT ' '
0x0d, 0x41,	// 0x0516: OUT 'A'
0x0d, 0x4c,	// 0x0518: OUT 'L'
0x0d, 0x55,	// 0x051a: OUT 'U'
0x0d, 0x20,	// 0x051c: OUT ' '
0x0d, 0x49,	// 0x051e: OUT 'I'
0x0d, 0x4d,	// 0x0520: OUT 'M'
0x0d, 0x10,	// 0x0522: OUT '\n'

////////////////////////////////////////////

// 0 -	OR

0x0d, 0x4f,	// 0x0524: OUT 'O'
0x0d, 0x52,	// 0x0526: OUT 'R'
0x0d, 0x2c,	// 0x0528: OUT ','
0x03, 0x65,	// 0x052a: LDR R0 #0x65
0x06, 0x80,	// 0x052c: OR  R0, #8
0xc3, 0x6d,	// 0x052e: LDR R3, #0x6D
0x12, 0xc7,	// 0x0530: TST R0, R3
0x3b, 0x09,	// 0x0532: BNE :FAIL
0xe5, 0xa2,	// 0x0534: (BNE continued)

0x03, 0x65,	// 0x0536: LDR R0 #0x65
0x06, 0x10,	// 0x0538: OR  R0, #1 //   65 = 01 OR 65
0xc3, 0x65,	// 0x053a: LDR R3, #0x65
0x12, 0xc7,	// 0x053c: TST R0, R3
0x3b, 0x09,	// 0x053e: BNE :FAIL
0xe5, 0xa2,	// 0x0540: (BNE continued)

////////////////////////////////////////////

// 1 - 	AND

0x0d, 0x41,	// 0x0542: OUT 'A'
0x0d, 0x4e,	// 0x0544: OUT 'N'
0x0d, 0x44,	// 0x0546: OUT 'D'
0x0d, 0x2c,	// 0x0548: OUT ','

0x83, 0x65,	// 0x054a: LDR R2, #0x65
0x86, 0xc2,	// 0x054c: AND  R2, #0xC  	// 0x04 = 0x0C AND 0x65
0xc3, 0x04,	// 0x054e: LDR R3, #0x04
0x12, 0xe7,	// 0x0550: TST R2, R3
0x3b, 0x09,	// 0x0552: BNE :FAIL
0xe5, 0xa2,	// 0x0554: (BNE continued)

0x83, 0x6e,	// 0x0556: LDR R2, #0x6E
0x86, 0xf2,	// 0x0558: AND R2, #0xF 	// 0x0E = 0x04 AND 0x65
0xc3, 0x0e,	// 0x055a: LDR R3, #0x0E
0x12, 0xe7,	// 0x055c: TST R2, R3
0x3b, 0x09,	// 0x055e: BNE :FAIL
0xe5, 0xa2,	// 0x0560: (BNE continued)

////////////////////////////////////////////

// 2 - 	XOR

0x0d, 0x58,	// 0x0562: OUT 'X'
0x0d, 0x4f,	// 0x0564: OUT 'O'
0x0d, 0x52,	// 0x0566: OUT 'R'
0x0d, 0x2c,	// 0x0568: OUT ','

0x83, 0x7b,	// 0x056a: LDR R2, #0x7B
0x86, 0x94,	// 0x056c: XOR R2, #0x9
0x43, 0x72,	// 0x056e: LDR R1, #0x72  // 0x82 = 0x09 XOR 0x7B
0x12, 0x67,	// 0x0570: TST R2, R1
0x3b, 0x09,	// 0x0572: BNE :FAIL
0xe5, 0xa2,	// 0x0574: (BNE continued)

0x03, 0x65,	// 0x0576: LDR R0, #0x65
0x06, 0x44,	// 0x0578: XOR R0, #0x4
0xc3, 0x61,	// 0x057a: LDR R3, #0x61 // 0x61 = 0x04 XOR 0x65
0x12, 0xc7,	// 0x057c: TST R0, R3
0x3b, 0x09,	// 0x057e: BNE :FAIL
0xe5, 0xa2,	// 0x0580: (BNE continued)


////////////////////////////////////////////

// 3 - 	ADD
// 7 -  ADC	- C = A + B + Cin

0x0d, 0x41,	// 0x0582: OUT 'A'
0x0d, 0x44,	// 0x0584: OUT 'D'
0x0d, 0x44,	// 0x0586: OUT 'D'
0x0d, 0x2d,	// 0x0588: OUT '-'
0x0d, 0x41,	// 0x058a: OUT 'A'
0x0d, 0x44,	// 0x058c: OUT 'D'
0x0d, 0x43,	// 0x058e: OUT 'C'
0x0d, 0x2c,	// 0x0590: OUT ','

0x43, 0xfe,	// 0x0592: LDR R1, #0xFE
0x46, 0x66,	// 0x0594: ADD R1, #6			// 0x104 = FE + 06
0x3b, 0x09,	// 0x0596: BCC :FAIL         	// Fail if Cary is not set
0xc5, 0xa2,	// 0x0598: (BCC continued)
0x46, 0x5e,	// 0x059a: ADC R1, #0x05  		// 0A = 05 + 04 + 1
0x3b, 0x09,	// 0x059c: BCS :FAIL         	// Fail if Cary is set
0x45, 0xa2,	// 0x059e: (BCS continued)
0x03, 0x0a,	// 0x05a0: LDR R0, #0x0A
0x12, 0x47,	// 0x05a2: TST R0, R1
0x3b, 0x09,	// 0x05a4: BNE :FAIL
0xe5, 0xa2,	// 0x05a6: (BNE continued)

////////////////////////////////////////////

// 3.1- SUB
// 7.1- SBC - C = A - B - NOT(Cin)

0x0d, 0x53,	// 0x05a8: OUT 'S'
0x0d, 0x55,	// 0x05aa: OUT 'U'
0x0d, 0x42,	// 0x05ac: OUT 'B'
0x0d, 0x2d,	// 0x05ae: OUT '-'
0x0d, 0x53,	// 0x05b0: OUT 'S'
0x0d, 0x42,	// 0x05b2: OUT 'B'
0x0d, 0x43,	// 0x05b4: OUT 'C'

// Substract with Borrow
0x83, 0x03,	// 0x05b6: LDR R2, #0x03
0x86, 0x57,	// 0x05b8: SUB R2, #0x05  		// FE = 03 - 05
0x3b, 0x09,	// 0x05ba: BCS :FAIL         	// Borrow is inverse of Carry. Borrow is set, so Carry is not set. Fail if Carry is set
0x45, 0xa2,	// 0x05bc: (BCS continued)
0xc3, 0x03,	// 0x05be: LDR R3, #0x03
0xc6, 0x2f,	// 0x05c0: SBC R3, #0x02   	//  01 = 03 - 2 -Borrow
0xd3, 0x07,	// 0x05c2: TST R3, #0x00
0x3b, 0x09,	// 0x05c4: BNE :FAIL
0xe5, 0xa2,	// 0x05c6: (BNE continued)

// Substract without Borrow
0x83, 0x13,	// 0x05c8: LDR R2, #0x13
0x86, 0x57,	// 0x05ca: SUB R2, #0x05  		// 0E = 13 - 05
0x3b, 0x09,	// 0x05cc: BCC :FAIL         	// Borrow is inverse of Carry. Borrow is not needed so Carry is set. Fail if Cary is not set
0xc5, 0xa2,	// 0x05ce: (BCC continued)
0x86, 0x7f,	// 0x05d0: SBC R2, #0x07      	// 0x07 = 0x0E - 0x07
0x93, 0x77,	// 0x05d2: TST R2, #0x07
0x3b, 0x09,	// 0x05d4: BNE :FAIL
0xe5, 0xa2,	// 0x05d6: (BNE continued)
0x0d, 0x10,	// 0x05d8: OUT '\n'

/////////////////////////////////// Op Code 0x1A - MAG, 0x1C - MGA
//
.define 2 mag_mga_result	0x5000


0x7b, 0x50,	// 0x05da: LDA %DP, H, mag_mga_result[1]
0x5b, 0x00,	// 0x05dc: LDA %DP, L, mag_mga_result[0]
0x83, 0x00,	// 0x05de: LDR R2, #0
0x97, 0x00,	// 0x05e0: SDW R2, %DP, #0     // Reset mag_mga_result

:mag_mga
0x0d, 0x4f,	// 0x05e2: OUT 'O'
0x0d, 0x70,	// 0x05e4: OUT 'p'
0x2d, 0x1a,	// 0x05e6: OUT #0x1A, I
0x0d, 0x2d,	// 0x05e8: OUT '-'
0x2d, 0x1c,	// 0x05ea: OUT #0x1C, I
0x0d, 0x3a,	// 0x05ec: OUT ':'
0x0d, 0x20,	// 0x05ee: OUT ' '
0x0d, 0x4d,	// 0x05f0: OUT 'M'
0x0d, 0x41,	// 0x05f2: OUT 'A'
0x0d, 0x47,	// 0x05f4: OUT 'G'
0x0d, 0x2d,	// 0x05f6: OUT '-'
0x0d, 0x4d,	// 0x05f8: OUT 'M'
0x0d, 0x47,	// 0x05fa: OUT 'G'
0x0d, 0x41,	// 0x05fc: OUT 'A'
0x0d, 0x10,	// 0x05fe: OUT '\n'

0x03, 0xff,	// 0x0600: LDR R0, #0xFF
:mag_mga_loop
0xfc, 0x00,	// 0x0602: MGA %BP, H, R0
0xdc, 0x00,	// 0x0604: MGA %BP, L, R0
0x7c, 0x00,	// 0x0606: MGA %DP, H, R0
0x5c, 0x00,	// 0x0608: MGA %DP, L, R0
0xbc, 0x00,	// 0x060a: MGA %SP, H, R0
0x9c, 0x00,	// 0x060c: MGA %SP, L, R0

0xfa, 0x03,	// 0x060e: MAG R3, %BP, H
0x12, 0x37,	// 0x0610: TST R3, R0
0x3b, 0x06,	// 0x0612: BNE :print_bad_line
0xe5, 0x42,	// 0x0614: (BNE continued)
0xda, 0x03,	// 0x0616: MAG R3, %BP, L
0x12, 0x37,	// 0x0618: TST R3, R0
0x3b, 0x06,	// 0x061a: BNE :print_bad_line
0xe5, 0x42,	// 0x061c: (BNE continued)

0xfa, 0x01,	// 0x061e: MAG R3, %DP, H
0x12, 0x37,	// 0x0620: TST R3, R0
0x3b, 0x06,	// 0x0622: BNE :print_bad_line
0xe5, 0x42,	// 0x0624: (BNE continued)
0xda, 0x01,	// 0x0626: MAG R3, %DP, L
0x12, 0x37,	// 0x0628: TST R3, R0
0x3b, 0x06,	// 0x062a: BNE :print_bad_line
0xe5, 0x42,	// 0x062c: (BNE continued)

0xfa, 0x02,	// 0x062e: MAG R3, %SP, H
0x12, 0x37,	// 0x0630: TST R3, R0
0x3b, 0x06,	// 0x0632: BNE :print_bad_line
0xe5, 0x42,	// 0x0634: (BNE continued)
0xda, 0x02,	// 0x0636: MAG R3, %SP, L
0x12, 0x37,	// 0x0638: TST R3, R0
0x3b, 0x06,	// 0x063a: BNE :print_bad_line
0xe5, 0x42,	// 0x063c: (BNE continued)

0x3b, 0x06,	// 0x063e: JMP :cont_mag_loop
0x05, 0x8c,	// 0x0640: (JMP continued)

:print_bad_line
// 1234567890123456
// R0: DP  BP   SP
//   0000,0000,0000
0x28, 0x00,	// 0x0642: OUT R0, I
0x0d, 0x3a,	// 0x0644: OUT ':'
0x0d, 0x20,	// 0x0646: OUT ' '
0x0d, 0x44,	// 0x0648: OUT 'D'
0x0d, 0x50,	// 0x064a: OUT 'P'
0x0d, 0x20,	// 0x064c: OUT ' '
0x0d, 0x20,	// 0x064e: OUT ' '
0x0d, 0x42,	// 0x0650: OUT 'B'
0x0d, 0x50,	// 0x0652: OUT 'P'
0x0d, 0x20,	// 0x0654: OUT ' '
0x0d, 0x20,	// 0x0656: OUT ' '
0x0d, 0x20,	// 0x0658: OUT ' '
0x0d, 0x53,	// 0x065a: OUT 'S'
0x0d, 0x50,	// 0x065c: OUT 'P'
0x0d, 0x10,	// 0x065e: OUT '\n'
// "  0000,0000,0000"
0x0d, 0x20,	// 0x0660: OUT ' '
0x0d, 0x20,	// 0x0662: OUT ' '
0xfa, 0x01,	// 0x0664: MAG R3, %DP, H
0x28, 0x30,	// 0x0666: OUT R3, I
0xda, 0x01,	// 0x0668: MAG R3, %DP, L
0x28, 0x30,	// 0x066a: OUT R3, I
0x0d, 0x2c,	// 0x066c: OUT ','

0xfa, 0x03,	// 0x066e: MAG R3, %BP, H
0x28, 0x30,	// 0x0670: OUT R3, I
0xda, 0x03,	// 0x0672: MAG R3, %BP, L
0x28, 0x30,	// 0x0674: OUT R3, I
0x0d, 0x2c,	// 0x0676: OUT ','

0xfa, 0x02,	// 0x0678: MAG R3, %SP, H
0x28, 0x30,	// 0x067a: OUT R3, I
0xda, 0x02,	// 0x067c: MAG R3, %SP, L
0x28, 0x30,	// 0x067e: OUT R3, I

0x0d, 0x10,	// 0x0680: OUT '\n'
0x7b, 0x50,	// 0x0682: LDA %DP, H, mag_mga_result[1]
0x5b, 0x00,	// 0x0684: LDA %DP, L, mag_mga_result[0]
0x95, 0x00,	// 0x0686: LDW R2, %DP, #0
0x86, 0x16,	// 0x0688: INC R2
0x97, 0x00,	// 0x068a: SDW R2, %DP, #0

:cont_mag_loop
0x13, 0x07,	// 0x068c: TST R0, #0
0x3b, 0x06,	// 0x068e: BEQ :after_mag_mga
0x65, 0x98,	// 0x0690: (BEQ continued)
0x06, 0x17,	// 0x0692: DEC R0
0x3b, 0x06,	// 0x0694: JMP :mag_mga_loop
0x05, 0x02,	// 0x0696: (JMP continued)

:after_mag_mga

0x7b, 0x50,	// 0x0698: LDA %DP, H, mag_mga_result[1]
0x5b, 0x00,	// 0x069a: LDA %DP, L, mag_mga_result[0]
0x95, 0x00,	// 0x069c: LDW R2, %DP, #0
0x93, 0x07,	// 0x069e: TST R2, #0
0x3b, 0x06,	// 0x06a0: BEQ :push_pop
0x65, 0xc2,	// 0x06a2: (BEQ continued)
0x0d, 0x46,	// 0x06a4: OUT 'F'
0x0d, 0x41,	// 0x06a6: OUT 'A'
0x0d, 0x49,	// 0x06a8: OUT 'I'
0x0d, 0x4c,	// 0x06aa: OUT 'L'
0x0d, 0x20,	// 0x06ac: OUT ' '
0x28, 0x20,	// 0x06ae: OUT R2, I
0x0d, 0x20,	// 0x06b0: OUT ' '
0x0d, 0x54,	// 0x06b2: OUT 'T'
0x0d, 0x49,	// 0x06b4: OUT 'I'
0x0d, 0x4d,	// 0x06b6: OUT 'M'
0x0d, 0x45,	// 0x06b8: OUT 'E'
0x0d, 0x53,	// 0x06ba: OUT 'S'
0x0d, 0x10,	// 0x06bc: OUT '\n'
0x3b, 0x09,	// 0x06be: JMP :FAIL
0x05, 0xa2,	// 0x06c0: (JMP continued)
//////////////////////////////////// Op Code 0x0E - PUSH, 0x0F - POP
//
//
:push_pop
.define 1, stack_test_length 0xE0
.define 2 stack_head	0x4500
0x0d, 0x4f,	// 0x06c2: OUT 'O'
0x0d, 0x70,	// 0x06c4: OUT 'p'
0x2d, 0x0e,	// 0x06c6: OUT #0x0E, I
0x0d, 0x2d,	// 0x06c8: OUT '-'
0x2d, 0x0f,	// 0x06ca: OUT #0x0F, I
0x0d, 0x3a,	// 0x06cc: OUT ':'
0x0d, 0x20,	// 0x06ce: OUT ' '
0x0d, 0x50,	// 0x06d0: OUT 'P'
0x0d, 0x55,	// 0x06d2: OUT 'U'
0x0d, 0x53,	// 0x06d4: OUT 'S'
0x0d, 0x48,	// 0x06d6: OUT 'H'
0x0d, 0x2d,	// 0x06d8: OUT '-'
0x0d, 0x50,	// 0x06da: OUT 'P'
0x0d, 0x4f,	// 0x06dc: OUT 'O'
0x0d, 0x50,	// 0x06de: OUT 'P'
0x0d, 0x10,	// 0x06e0: OUT '\n'

0xbb, 0x45,	// 0x06e2: LDA %SP, H, stack_head[1]
0x9b, 0x00,	// 0x06e4: LDA %SP, L, stack_head[0]

0x43, 0xe0,	// 0x06e6: LDR R1, stack_test_length

// Push Loop 0x4500 -> 0x4410
:push_loop
0x0e, 0x10,	// 0x06e8: PUSH R1
0x46, 0x17,	// 0x06ea: DEC R1
0x3b, 0x06,	// 0x06ec: BNE :push_loop
0xe5, 0xe8,	// 0x06ee: (BNE continued)

0xc3, 0xe0,	// 0x06f0: LDR R3, stack_test_length
// Pop & Check loop
:pop_loop
