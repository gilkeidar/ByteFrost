0x2d, 0x11,	// 0x08fa: OUT #0x11, I
0x0d, 0x3a,	// 0x08fc: OUT ':'
0x0d, 0x20,	// 0x08fe: OUT ' '

0x0d, 0x4a,	// 0x0900: OUT 'J'
0x0d, 0x53,	// 0x0902: OUT 'S'
0x0d, 0x52,	// 0x0904: OUT 'R'
0x0d, 0x20,	// 0x0906: OUT ' '
0x0d, 0x52,	// 0x0908: OUT 'R'
0x0d, 0x54,	// 0x090a: OUT 'T'
0x0d, 0x53,	// 0x090c: OUT 'S'
0x0d, 0x10,	// 0x090e: OUT '\n'

.define 2 stack_head2		0xAAAA

.define 2 recursion_level 	0x6000

0xbb, 0xaa,	// 0x0910: LDA %SP, H, stack_head2[1]
0x9b, 0xaa,	// 0x0912: LDA %SP, L, stack_head2[0]

0x7b, 0x60,	// 0x0914: LDA %DP, H, recursion_level[1]
0x5b, 0x00,	// 0x0916: LDA %DP, L, recursion_level[0]

// Recursion level
0xc3, 0x06,	// 0x0918: LDR R3, #6
0xd7, 0x00,	// 0x091a: SDW R3, %DP, #0

0x0d, 0x50,	// 0x091c: OUT 'P'
0x0d, 0x55,	// 0x091e: OUT 'U'
0x0d, 0x53,	// 0x0920: OUT 'S'
0x0d, 0x48,	// 0x0922: OUT 'H'
0x0d, 0x20,	// 0x0924: OUT ' '
0x5b, 0x3e,	// 0x0926: CALL :recursion
0x7b, 0x09,	// 0x0928: (CALL continued)
0x10, 0x00,	// 0x092a: (CALL continued)
0x0d, 0x10,	// 0x092c: OUT '\n'
0x0d, 0x42,	// 0x092e: OUT 'B'
0x0d, 0x61,	// 0x0930: OUT 'a'
0x0d, 0x63,	// 0x0932: OUT 'c'
0x0d, 0x6b,	// 0x0934: OUT 'k'
0x0d, 0x21,	// 0x0936: OUT '!'
0x0d, 0x10,	// 0x0938: OUT '\n'
0x3b, 0x09,	// 0x093a: JMP :PASS
0x05, 0x82,	// 0x093c: (JMP continued)

:recursion
0x7b, 0x60,	// 0x093e: LDA %DP, H, recursion_level[1]
0x5b, 0x00,	// 0x0940: LDA %DP, L, recursion_level[0]
0xd5, 0x00,	// 0x0942: LDW R3, %DP, #0

0x28, 0x30,	// 0x0944: OUT R3, I
0x0d, 0x20,	// 0x0946: OUT ' '

0x0e, 0x30,	// 0x0948: PUSH R3

0xc6, 0x17,	// 0x094a: DEC R3
0x3b, 0x09,	// 0x094c: BNE :keep_going
0xe5, 0x6a,	// 0x094e: (BNE continued)
// Stop condition met
0x83, 0x01,	// 0x0950: LDR R2 , #1
0xcf, 0x00,	// 0x0952: POP R3
0x0d, 0x10,	// 0x0954: OUT '\n'
0x0d, 0x50,	// 0x0956: OUT 'P'
0x0d, 0x4f,	// 0x0958: OUT 'O'
0x0d, 0x50,	// 0x095a: OUT 'P'
0x0d, 0x20,	// 0x095c: OUT ' '
0x28, 0x30,	// 0x095e: OUT R3, I
0x0d, 0x20,	// 0x0960: OUT ' '
0x12, 0xe7,	// 0x0962: TST R2, R3
0x3b, 0x09,	// 0x0964: BNE :FAIL
0xe5, 0xa2,	// 0x0966: (BNE continued)
0x11, 0x00,	// 0x0968: RTS   // Rolling out of deepest recursion

:keep_going
0xd7, 0x00,	// 0x096a: SDW R3, %DP, #0
0x5b, 0x3e,	// 0x096c: CALL :recursion
0x7b, 0x09,	// 0x096e: (CALL continued)
0x10, 0x00,	// 0x0970: (CALL continued)

// Retrun
0xcf, 0x00,	// 0x0972: POP R3

0x28, 0x30,	// 0x0974: OUT R3, I
0x0d, 0x20,	// 0x0976: OUT ' '
0x86, 0x16,	// 0x0978: INC R2
0x12, 0xe7,	// 0x097a: TST R2, R3
0x3b, 0x09,	// 0x097c: BNE :FAIL
0xe5, 0xa2,	// 0x097e: (BNE continued)
0x11, 0x00,	// 0x0980: RTS  // Rolling out of intemediate recursion step

////////////////////////////////////////////

:PASS
// BIST is not using SP as a Stack Pointer, so it needs restore it at the end
0x7b, 0xdf,	// 0x0982: LDA %DP, H, stack_pointer[1]
0x5b, 0x00,	// 0x0984: LDA %DP, L, stack_pointer[0]
0xd5, 0x01,	// 0x0986: LDW R3, %DP, #1
0x95, 0x00,	// 0x0988: LDW R2, %DP, #0
0xbc, 0x30,	// 0x098a: MGA %SP, H, R3
0x9c, 0x20,	// 0x098c: MGA %SP, L, R2

0x0d, 0x10,	// 0x098e: OUT '\n'
0x0d, 0x50,	// 0x0990: OUT 'P'
0x0d, 0x41,	// 0x0992: OUT 'A'
0x0d, 0x53,	// 0x0994: OUT 'S'
0x0d, 0x53,	// 0x0996: OUT 'S'
0x0d, 0x20,	// 0x0998: OUT ' '
0x5b, 0xb6,	// 0x099a: CALL :Test_duration
0x7b, 0x09,	// 0x099c: (CALL continued)
0x10, 0x00,	// 0x099e: (CALL continued)
0x11, 0x00,	// 0x09a0: RTS
///////////////////////////////////////////////
:FAIL
0x0d, 0x10,	// 0x09a2: OUT '\n'
0x0d, 0x46,	// 0x09a4: OUT 'F'
0x0d, 0x41,	// 0x09a6: OUT 'A'
0x0d, 0x49,	// 0x09a8: OUT 'I'
0x0d, 0x4c,	// 0x09aa: OUT 'L'
0x0d, 0x20,	// 0x09ac: OUT ' '
0x5b, 0xb6,	// 0x09ae: CALL :Test_duration
0x7b, 0x09,	// 0x09b0: (CALL continued)
0x10, 0x00,	// 0x09b2: (CALL continued)
0x01, 0x00,	// 0x09b4: BRK
///////////////////////////////////////////////
:Test_duration
0x7b, 0xe2,	// 0x09b6: LDA %DP, H, counter_base[1]
0x5b, 0x00,	// 0x09b8: LDA %DP, L, counter_base[0]

0x17, 0x01,	// 0x09ba: SDW R0, %DP, #1  // Latch Counter
// LDW R0, %DP, #5  // Print Byte4
// OUT R0, I
0x15, 0x04,	// 0x09bc: LDW R0, %DP, #4  // Print Byte3
0x28, 0x00,	// 0x09be: OUT R0, I
0x55, 0x03,	// 0x09c0: LDW R1, %DP, #3  // Print Byte2
0x28, 0x10,	// 0x09c2: OUT R1, I
0x95, 0x02,	// 0x09c4: LDW R2, %DP, #2  // Print Byte1
0x28, 0x20,	// 0x09c6: OUT R2, I
0x0d, 0x10,	// 0x09c8: OUT '\n'
0x11, 0x00,	// 0x09ca: RTS


