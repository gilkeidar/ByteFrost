0x0d, 0x57,	// 0x0742: OUT 'W'

0x0d, 0x10,	// 0x0744: OUT '\n'

// The loop over the three pointers must be seperated incase
// the pointer selection does not work properly
0x03, 0xe0,	// 0x0746: LDR R0 stack_test_length
:ldw_loop_dp
0x55, 0xff,	// 0x0748: LDW R1, %DP, #-1 // Push decrease SP before inserting data
