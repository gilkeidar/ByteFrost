:ldw_sdw
//Set PASS/FAIL flag
0x83, 0x00,	// 0x06ce: LDR R2, #0   // FAIL flag

0xbb, 0x45,	// 0x06d0: LDA %SP, H, stack_head[1]
0x9b, 0x00,	// 0x06d2: LDA %SP, L, stack_head[0]
0x7b, 0x45,	// 0x06d4: LDA %DP, H, stack_head[1]
0x5b, 0x00,	// 0x06d6: LDA %DP, L, stack_head[0]
0xfb, 0x45,	// 0x06d8: LDA %BP, H, stack_head[1]
0xdb, 0x00,	// 0x06da: LDA %BP, L, stack_head[0]

0x0d, 0x4f,	// 0x06dc: OUT _O, A
0x0d, 0x70,	// 0x06de: OUT _p, A
0x2d, 0x14,	// 0x06e0: OUT #0x14, I
0x0d, 0x2d,	// 0x06e2: OUT DASH, A
0x2d, 0x15,	// 0x06e4: OUT #0x15, I
0x0d, 0x3a,	// 0x06e6: OUT COLON, A
0x0d, 0x20,	// 0x06e8: OUT SPACE, A
0x0d, 0x4c,	// 0x06ea: OUT _L, A
0x0d, 0x44,	// 0x06ec: OUT _D, A
0x0d, 0x57,	// 0x06ee: OUT _W, A

0x0d, 0x10,	// 0x06f0: OUT NEW_LINE, A

// The loop over the three pointers must be seperated incase
// the pointer selection does not work properly
0x03, 0xe0,	// 0x06f2: LDR R0 stack_test_length
:ldw_loop_dp
0x55, 0xff,	// 0x06f4: LDW R1, %DP, #-1 // Push decrease SP before inserting data
// So the data start at -1 of the SP base
0x12, 0x17,	// 0x06f6: TST R1, R0
0x3b, 0x07,	// 0x06f8: BEQ :ldw_cont_dp
0x65, 0x0e,	// 0x06fa: (BEQ continued)

0x28, 0x00,	// 0x06fc: OUT R0, I
0x0d, 0x23,	// 0x06fe: OUT '#'
0x0d, 0x20,	// 0x0700: OUT SPACE, A
0x0d, 0x44,	// 0x0702: OUT _D, A
0x0d, 0x50,	// 0x0704: OUT _P, A
0x0d, 0x2a,	// 0x0706: OUT '*'
0x28, 0x10,	// 0x0708: OUT R1, I
0x0d, 0x10,	// 0x070a: OUT NEW_LINE, A
0x83, 0x01,	// 0x070c: LDR R2, #1
:ldw_cont_dp
0x59, 0xff,	// 0x070e: MAA %DP, %DP, #-1
0x06, 0x17,	// 0x0710: DEC R0
0x3b, 0x06,	// 0x0712: BNE :ldw_loop_dp
0xe5, 0xf4,	// 0x0714: (BNE continued)

0x03, 0xe0,	// 0x0716: LDR R0 stack_test_length
:ldw_loop_bp
0x75, 0xff,	// 0x0718: LDW R1, %BP, #-1 // Push decrease SP before inserting data
// So the data start at -1 of the SP base
0x12, 0x17,	// 0x071a: TST R1, R0
0x3b, 0x07,	// 0x071c: BEQ :ldw_cont_bp
0x65, 0x32,	// 0x071e: (BEQ continued)

0x28, 0x00,	// 0x0720: OUT R0, I
0x0d, 0x23,	// 0x0722: OUT '#'
0x0d, 0x20,	// 0x0724: OUT SPACE, A
0x0d, 0x42,	// 0x0726: OUT _B, A
0x0d, 0x50,	// 0x0728: OUT _P, A
0x0d, 0x2a,	// 0x072a: OUT '*'
0x28, 0x10,	// 0x072c: OUT R1, I
0x0d, 0x10,	// 0x072e: OUT NEW_LINE, A
0x83, 0x01,	// 0x0730: LDR R2, #1
:ldw_cont_bp

0xf9, 0xff,	// 0x0732: MAA %BP, %BP, #-1
0x06, 0x17,	// 0x0734: DEC R0
0x3b, 0x07,	// 0x0736: BNE :ldw_loop_bp
0xe5, 0x18,	// 0x0738: (BNE continued)

0x03, 0xe0,	// 0x073a: LDR R0 stack_test_length
:ldw_loop_sp
0x74, 0xff,	// 0x073c: LDW R1, %SP, #-1 // Push decrease SP before inserting data
// So the data start at -1 of the SP base
0x12, 0x17,	// 0x073e: TST R1, R0

0x3b, 0x07,	// 0x0740: BEQ :ldw_cont_sp
0x65, 0x56,	// 0x0742: (BEQ continued)
0x28, 0x00,	// 0x0744: OUT R0, I
0x0d, 0x23,	// 0x0746: OUT '#'
0x0d, 0x20,	// 0x0748: OUT SPACE, A
0x0d, 0x53,	// 0x074a: OUT _S, A
0x0d, 0x50,	// 0x074c: OUT _P, A
0x0d, 0x2a,	// 0x074e: OUT '*'
0x28, 0x10,	// 0x0750: OUT R1, I
0x0d, 0x10,	// 0x0752: OUT NEW_LINE, A
0x83, 0x01,	// 0x0754: LDR R2, #1
:ldw_cont_sp

0xb8, 0xff,	// 0x0756: MAA %SP, %SP, #-1
0x06, 0x17,	// 0x0758: DEC R0
0x3b, 0x07,	// 0x075a: BNE :ldw_loop_sp
0xe5, 0x3c,	// 0x075c: (BNE continued)
0x93, 0x07,	// 0x075e: TST R2, #0
0x3b, 0x07,	// 0x0760: BEQ :sdw_test
0x65, 0x68,	// 0x0762: (BEQ continued)
0x3b, 0x09,	// 0x0764: JMP :FAIL
0x05, 0x3e,	// 0x0766: (JMP continued)
