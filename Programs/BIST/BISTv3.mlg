:tst_call_jsr_rst
0x0d, 0x4f,	// 0x089e: OUT _O, A
0x0d, 0x70,	// 0x08a0: OUT _p, A
0x2d, 0x10,	// 0x08a2: OUT #0x10, I
0x0d, 0x2d,	// 0x08a4: OUT DASH, A
0x2d, 0x11,	// 0x08a6: OUT #0x11, I
0x0d, 0x3a,	// 0x08a8: OUT COLON, A
0x0d, 0x20,	// 0x08aa: OUT SPACE, A

0x0d, 0x4a,	// 0x08ac: OUT 'J'
0x0d, 0x53,	// 0x08ae: OUT 'S'
0x0d, 0x52,	// 0x08b0: OUT 'R'
0x0d, 0x20,	// 0x08b2: OUT ' '
0x0d, 0x52,	// 0x08b4: OUT 'R'
0x0d, 0x54,	// 0x08b6: OUT 'T'
0x0d, 0x53,	// 0x08b8: OUT 'S'
0x0d, 0x10,	// 0x08ba: OUT '\n'

.define 2 stack_head2		0xAAAA

.define 2 recursion_level 	0x6000

0xbb, 0xaa,	// 0x08bc: LDA %SP, H, stack_head2[1]
0x9b, 0xaa,	// 0x08be: LDA %SP, L, stack_head2[0]

0x7b, 0x60,	// 0x08c0: LDA %DP, H, recursion_level[1]
0x5b, 0x00,	// 0x08c2: LDA %DP, L, recursion_level[0]

// Recursion level
0xc3, 0x06,	// 0x08c4: LDR R3, #6
0xd7, 0x00,	// 0x08c6: SDW R3, %DP, #0

0x0d, 0x50,	// 0x08c8: OUT 'P'
0x0d, 0x55,	// 0x08ca: OUT 'U'
0x0d, 0x53,	// 0x08cc: OUT 'S'
0x0d, 0x48,	// 0x08ce: OUT 'H'
0x0d, 0x20,	// 0x08d0: OUT ' '
0x5b, 0xea,	// 0x08d2: CALL :recursion
0x7b, 0x08,	// 0x08d4: (CALL continued)
0x10, 0x00,	// 0x08d6: (CALL continued)
0x0d, 0x10,	// 0x08d8: OUT '\n'
0x0d, 0x42,	// 0x08da: OUT 'B'
0x0d, 0x61,	// 0x08dc: OUT 'a'
0x0d, 0x63,	// 0x08de: OUT 'c'
0x0d, 0x6b,	// 0x08e0: OUT 'k'
0x0d, 0x21,	// 0x08e2: OUT '!'
0x0d, 0x10,	// 0x08e4: OUT '\n'
0x3b, 0x09,	// 0x08e6: JMP :PASS
0x05, 0x2e,	// 0x08e8: (JMP continued)

:recursion
0x7b, 0x60,	// 0x08ea: LDA %DP, H, recursion_level[1]
0x5b, 0x00,	// 0x08ec: LDA %DP, L, recursion_level[0]
0xd5, 0x00,	// 0x08ee: LDW R3, %DP, #0

0x28, 0x30,	// 0x08f0: OUT R3, I
0x0d, 0x20,	// 0x08f2: OUT ' '

0x0e, 0x30,	// 0x08f4: PUSH R3

0xc6, 0x17,	// 0x08f6: DEC R3
0x3b, 0x09,	// 0x08f8: BNE :keep_going
0xe5, 0x16,	// 0x08fa: (BNE continued)
// Stop condition met
0x83, 0x01,	// 0x08fc: LDR R2 , #1
0xcf, 0x00,	// 0x08fe: POP R3
0x0d, 0x10,	// 0x0900: OUT '\n'
0x0d, 0x50,	// 0x0902: OUT 'P'
0x0d, 0x4f,	// 0x0904: OUT 'O'
0x0d, 0x50,	// 0x0906: OUT 'P'
0x0d, 0x20,	// 0x0908: OUT ' '
0x28, 0x30,	// 0x090a: OUT R3, I
0x0d, 0x20,	// 0x090c: OUT ' '
0x12, 0xe7,	// 0x090e: TST R2, R3
0x3b, 0x09,	// 0x0910: BNE :FAIL
0xe5, 0x3e,	// 0x0912: (BNE continued)
0x11, 0x00,	// 0x0914: RTS   // Rolling out of deepest recursion

:keep_going
0xd7, 0x00,	// 0x0916: SDW R3, %DP, #0
0x5b, 0xea,	// 0x0918: CALL :recursion
0x7b, 0x08,	// 0x091a: (CALL continued)
0x10, 0x00,	// 0x091c: (CALL continued)

// Retrun
0xcf, 0x00,	// 0x091e: POP R3

0x28, 0x30,	// 0x0920: OUT R3, I
0x0d, 0x20,	// 0x0922: OUT ' '
0x86, 0x16,	// 0x0924: INC R2
0x12, 0xe7,	// 0x0926: TST R2, R3
0x3b, 0x09,	// 0x0928: BNE :FAIL
0xe5, 0x3e,	// 0x092a: (BNE continued)
0x11, 0x00,	// 0x092c: RTS  // Rolling out of intemediate recursion step

////////////////////////////////////////////

:PASS
0x0d, 0x10,	// 0x092e: OUT NEW_LINE, A
0x0d, 0x50,	// 0x0930: OUT _P, A
0x0d, 0x41,	// 0x0932: OUT _A, A
0x0d, 0x53,	// 0x0934: OUT _S, A
0x0d, 0x53,	// 0x0936: OUT _S, A
0x0d, 0x20,	// 0x0938: OUT SPACE, A
0x3b, 0x09,	// 0x093a: JMP :Test_duration
0x05, 0x4a,	// 0x093c: (JMP continued)
///////////////////////////////////////////////
:FAIL
0x0d, 0x10,	// 0x093e: OUT NEW_LINE, A
0x0d, 0x46,	// 0x0940: OUT _F, A
0x0d, 0x41,	// 0x0942: OUT _A, A
0x0d, 0x49,	// 0x0944: OUT _I, A
0x0d, 0x4c,	// 0x0946: OUT _L, A
0x0d, 0x20,	// 0x0948: OUT SPACE, A

///////////////////////////////////////////////
:Test_duration
0x7b, 0xe2,	// 0x094a: LDA %DP, H, counter_base[1]
0x5b, 0x00,	// 0x094c: LDA %DP, L, counter_base[0]

0x17, 0x01,	// 0x094e: SDW R0, %DP, #1  // Latch Counter
// LDW R0, %DP, #5  // Print Byte4
// OUT R0, I
0x15, 0x04,	// 0x0950: LDW R0, %DP, #4  // Print Byte3
0x28, 0x00,	// 0x0952: OUT R0, I
0x55, 0x03,	// 0x0954: LDW R1, %DP, #3  // Print Byte2
0x28, 0x10,	// 0x0956: OUT R1, I
