0x03, 0x65,	// 0x0522: LDR R0, #0x65
0x06, 0x44,	// 0x0524: XOR R0, #0x4
0xc3, 0x61,	// 0x0526: LDR R3, #0x61 // 0x61 = 0x04 XOR 0x65
0x12, 0xc7,	// 0x0528: TST R0, R3
0x3b, 0x09,	// 0x052a: BNE :FAIL
0xe5, 0x3e,	// 0x052c: (BNE continued)


////////////////////////////////////////////

// 3 - 	ADD
// 7 -  ADC	- C = A + B + Cin

0x0d, 0x41,	// 0x052e: OUT _A, A
0x0d, 0x44,	// 0x0530: OUT _D, A
0x0d, 0x44,	// 0x0532: OUT _D, A
0x0d, 0x2d,	// 0x0534: OUT DASH, A
0x0d, 0x41,	// 0x0536: OUT _A, A
0x0d, 0x44,	// 0x0538: OUT _D, A
0x0d, 0x43,	// 0x053a: OUT _C, A
0x0d, 0x2c,	// 0x053c: OUT COMMA, A

0x43, 0xfe,	// 0x053e: LDR R1, #0xFE
0x46, 0x66,	// 0x0540: ADD R1, #6			// 0x104 = FE + 06
0x3b, 0x09,	// 0x0542: BCC :FAIL         	// Fail if Cary is not set
0xc5, 0x3e,	// 0x0544: (BCC continued)
0x46, 0x5e,	// 0x0546: ADC R1, #0x05  		// 0A = 05 + 04 + 1
0x3b, 0x09,	// 0x0548: BCS :FAIL         	// Fail if Cary is set
0x45, 0x3e,	// 0x054a: (BCS continued)
0x03, 0x0a,	// 0x054c: LDR R0, #0x0A
0x12, 0x47,	// 0x054e: TST R0, R1
0x3b, 0x09,	// 0x0550: BNE :FAIL
0xe5, 0x3e,	// 0x0552: (BNE continued)

////////////////////////////////////////////

// 3.1- SUB
// 7.1- SBC - C = A - B - NOT(Cin)

0x0d, 0x53,	// 0x0554: OUT _S, A
0x0d, 0x55,	// 0x0556: OUT _U, A
0x0d, 0x42,	// 0x0558: OUT _B, A
0x0d, 0x2d,	// 0x055a: OUT DASH, A
0x0d, 0x53,	// 0x055c: OUT _S, A
0x0d, 0x42,	// 0x055e: OUT _B, A
0x0d, 0x43,	// 0x0560: OUT _C, A

// Substract with Borrow
0x83, 0x03,	// 0x0562: LDR R2, #0x03
0x86, 0x57,	// 0x0564: SUB R2, #0x05  		// FE = 03 - 05
0x3b, 0x09,	// 0x0566: BCS :FAIL         	// Borrow is inverse of Carry. Borrow is set, so Carry is not set. Fail if Carry is set
0x45, 0x3e,	// 0x0568: (BCS continued)
0xc3, 0x03,	// 0x056a: LDR R3, #0x03
0xc6, 0x2f,	// 0x056c: SBC R3, #0x02   	//  01 = 03 - 2 -Borrow
0xd3, 0x07,	// 0x056e: TST R3, #0x00
0x3b, 0x09,	// 0x0570: BNE :FAIL
0xe5, 0x3e,	// 0x0572: (BNE continued)

// Substract without Borrow
0x83, 0x13,	// 0x0574: LDR R2, #0x13
0x86, 0x57,	// 0x0576: SUB R2, #0x05  		// 0E = 13 - 05
0x3b, 0x09,	// 0x0578: BCC :FAIL         	// Borrow is inverse of Carry. Borrow is not needed so Carry is set. Fail if Cary is not set
0xc5, 0x3e,	// 0x057a: (BCC continued)
0x86, 0x7f,	// 0x057c: SBC R2, #0x07      	// 0x07 = 0x0E - 0x07
0x93, 0x77,	// 0x057e: TST R2, #0x07
0x3b, 0x09,	// 0x0580: BNE :FAIL
0xe5, 0x3e,	// 0x0582: (BNE continued)
0x0d, 0x10,	// 0x0584: OUT NEW_LINE, A

