0x83, 0x00,	// 0x077e: LDR R2, #0   // FAIL flag
.define 2 test_area 0x6666
.define 1 loop_length 0x88
0xbb, 0x66,	// 0x0780: LDA %SP, H, test_area[1]
0x9b, 0x66,	// 0x0782: LDA %SP, L, test_area[0]
