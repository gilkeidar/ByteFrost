0x0d, 0x6d,	// 0x04cc: OUT _m, A
0x0d, 0x10,	// 0x04ce: OUT NEW_LINE, A

////////////////////////////////////////////

// 0 -	OR

0x0d, 0x4f,	// 0x04d0: OUT _O, A
0x0d, 0x52,	// 0x04d2: OUT _R, A
0x0d, 0x2c,	// 0x04d4: OUT COMMA, A
0x03, 0x65,	// 0x04d6: LDR R0 #0x65
0x06, 0x80,	// 0x04d8: OR  R0, #8
0xc3, 0x6d,	// 0x04da: LDR R3, #0x6D
0x12, 0xc7,	// 0x04dc: TST R0, R3
0x3b, 0x09,	// 0x04de: BNE :FAIL
0xe5, 0x3e,	// 0x04e0: (BNE continued)

0x03, 0x65,	// 0x04e2: LDR R0 #0x65
0x06, 0x10,	// 0x04e4: OR  R0, #1 //   65 = 01 OR 65
0xc3, 0x65,	// 0x04e6: LDR R3, #0x65
0x12, 0xc7,	// 0x04e8: TST R0, R3
0x3b, 0x09,	// 0x04ea: BNE :FAIL
0xe5, 0x3e,	// 0x04ec: (BNE continued)

////////////////////////////////////////////

// 1 - 	AND

0x0d, 0x41,	// 0x04ee: OUT _A, A
0x0d, 0x4e,	// 0x04f0: OUT _N, A
0x0d, 0x44,	// 0x04f2: OUT _D, A
0x0d, 0x2c,	// 0x04f4: OUT COMMA, A

0x83, 0x65,	// 0x04f6: LDR R2, #0x65
0x86, 0xc2,	// 0x04f8: AND  R2, #0xC  	// 0x04 = 0x0C AND 0x65
0xc3, 0x04,	// 0x04fa: LDR R3, #0x04
0x12, 0xe7,	// 0x04fc: TST R2, R3
0x3b, 0x09,	// 0x04fe: BNE :FAIL
0xe5, 0x3e,	// 0x0500: (BNE continued)

0x83, 0x6e,	// 0x0502: LDR R2, #0x6E
0x86, 0xf2,	// 0x0504: AND R2, #0xF 	// 0x0E = 0x04 AND 0x65
0xc3, 0x0e,	// 0x0506: LDR R3, #0x0E
0x12, 0xe7,	// 0x0508: TST R2, R3
0x3b, 0x09,	// 0x050a: BNE :FAIL
0xe5, 0x3e,	// 0x050c: (BNE continued)

////////////////////////////////////////////

// 2 - 	XOR

0x0d, 0x58,	// 0x050e: OUT _X, A
0x0d, 0x4f,	// 0x0510: OUT _O, A
0x0d, 0x52,	// 0x0512: OUT _R, A
0x0d, 0x2c,	// 0x0514: OUT COMMA, A

0x83, 0x7b,	// 0x0516: LDR R2, #0x7B
0x86, 0x94,	// 0x0518: XOR R2, #0x9
0x43, 0x72,	// 0x051a: LDR R1, #0x72  // 0x82 = 0x09 XOR 0x7B
0x12, 0x67,	// 0x051c: TST R2, R1
0x3b, 0x09,	// 0x051e: BNE :FAIL
